# Copy to .env.development (gitignored) and fill in.

# Local API (hono-workers dev server)
PUBLIC_API_URL=http://localhost:8787/api/v1

# Google reCAPTCHA v3 SITE key (public value, browser-safe).
# Leave unset to disable the captcha locally — the backend skips
# verification when RECAPTCHA_SECRET_KEY is not configured either.
PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-v2-site-key
