---
const currentPath = Astro.url.pathname;
const paths = currentPath.split("/").filter(Boolean);

const breadcrumbs = paths.map((path, index) => {
    const href = `/${paths.slice(0, index + 1).join("/")}`;
    let label = path
        .replace(/-/g, " ")
        .replace(/\b\w/g, (c) => c.toUpperCase());

    if (path === "admin") label = "Admin";
    if (path === "contact") label = "Contacts";

    return {
        label,
        href,
        isLast: index === paths.length - 1,
    };
});

if (paths.length === 1 && paths[0] === "admin") {
    breadcrumbs[0].isLast = false;
    breadcrumbs.push({ label: "Dashboard", href: "", isLast: true });
}
---

<header
    class="h-16 border-b border-slate-200 dark:border-slate-700 flex items-center justify-between px-6 bg-white/85 dark:bg-slate-900/50 backdrop-blur-xl sticky top-0 z-20"
>
    <div class="flex items-center gap-3">
        <div class="flex items-center gap-2">
            <button
                id="toggle-sidebar"
                class="md:hidden text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-200 p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                aria-label="Toggle sidebar"
                type="button"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-6 w-6"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </button>
            <button
                id="minimize-sidebar"
                class="hidden md:inline-flex text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-200 p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                aria-label="Minimize sidebar"
                type="button"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-5 w-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </button>
        </div>
        <div
            class="hidden sm:flex items-center text-sm text-slate-500 dark:text-slate-400 gap-2"
        >
            {
                breadcrumbs.map((crumb, index) => (
                    <>
                        {index > 0 && (
                            <span class="text-slate-300 dark:text-slate-600">
                                /
                            </span>
                        )}
                        {crumb.isLast ? (
                            <span class="text-slate-900 dark:text-slate-200">
                                {crumb.label}
                            </span>
                        ) : (
                            <a
                                href={crumb.href}
                                class="text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-200 transition-colors"
                            >
                                {crumb.label}
                            </a>
                        )}
                    </>
                ))
            }
        </div>
    </div>

    <div class="flex items-center gap-2 ml-auto">
        <!-- Theme Toggle -->
        <button
            id="admin-theme-toggle"
            type="button"
            aria-label="Toggle theme"
            class="admin-theme-toggle-btn p-2 text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-200 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
        >
            <svg
                id="admin-theme-sun"
                class="hidden h-5 w-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"
                ></path>
            </svg>
            <svg
                id="admin-theme-moon"
                class="block h-5 w-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
                ></path>
            </svg>
        </button>


        <!-- Settings Quick Link -->
        <a
            href="/admin/settings"
            class="p-2 text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-200 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
            aria-label="Settings"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z"
                ></path>
            </svg>
        </a>
    </div>
</header>
<style>
    .admin-theme-toggle-btn {
        transform-origin: center;
        transition:
            transform 0.15s ease,
            background-color 0.2s,
            color 0.2s;
    }
    .admin-theme-toggle-btn:active {
        transform: scale(0.8);
    }
    #admin-theme-sun,
    #admin-theme-moon {
        transform-origin: center;
    }
    @keyframes admin-icon-into-dark {
        0% {
            transform: rotate(-60deg) scale(0.3);
            opacity: 0;
        }
        70% {
            transform: rotate(8deg) scale(1.15);
            opacity: 1;
        }
        100% {
            transform: rotate(0deg) scale(1);
            opacity: 1;
        }
    }
    @keyframes admin-icon-into-light {
        0% {
            transform: rotate(60deg) scale(0.3);
            opacity: 0;
        }
        70% {
            transform: rotate(-8deg) scale(1.15);
            opacity: 1;
        }
        100% {
            transform: rotate(0deg) scale(1);
            opacity: 1;
        }
    }
    .admin-icon-anim-sun {
        animation: admin-icon-into-dark 0.4s cubic-bezier(0.34, 1.56, 0.64, 1)
            both;
    }
    .admin-icon-anim-moon {
        animation: admin-icon-into-light 0.4s cubic-bezier(0.34, 1.56, 0.64, 1)
            both;
    }
    #minimize-sidebar svg {
        transition: transform 200ms ease;
    }
    :root[data-admin-sidebar="minimized"] #minimize-sidebar svg {
        transform: rotate(180deg);
    }
</style>

<script>
    declare global {
        interface Window {
            toggleAdminSidebar: () => void;
            minimizeAdminSidebar: () => void;
        }
    }

    function setupNavbar() {
        const themeToggle = document.getElementById("admin-theme-toggle");
        const sunIcon = document.getElementById("admin-theme-sun");
        const moonIcon = document.getElementById("admin-theme-moon");

        const syncThemeIcon = (animate = false) => {
            const isDark = document.documentElement.classList.contains("dark");
            if (!sunIcon || !moonIcon) return;

            if (isDark) {
                moonIcon.classList.add("hidden");
                moonIcon.classList.remove("block", "admin-icon-anim-moon");
                sunIcon.classList.remove("hidden");
                sunIcon.classList.add("block");
                if (animate) {
                    sunIcon.classList.remove("admin-icon-anim-sun");
                    void (sunIcon as HTMLElement).offsetWidth;
                    sunIcon.classList.add("admin-icon-anim-sun");
                }
            } else {
                sunIcon.classList.add("hidden");
                sunIcon.classList.remove("block", "admin-icon-anim-sun");
                moonIcon.classList.remove("hidden");
                moonIcon.classList.add("block");
                if (animate) {
                    moonIcon.classList.remove("admin-icon-anim-moon");
                    void (moonIcon as HTMLElement).offsetWidth;
                    moonIcon.classList.add("admin-icon-anim-moon");
                }
            }
        };

        syncThemeIcon();

        if (themeToggle && themeToggle.dataset.bound !== "true") {
            themeToggle.addEventListener("click", () => {
                const willBeDark =
                    !document.documentElement.classList.contains("dark");
                const rect = themeToggle.getBoundingClientRect();
                const x = rect.left + rect.width / 2;
                const y = rect.top + rect.height / 2;
                const radius = Math.hypot(
                    Math.max(x, window.innerWidth - x),
                    Math.max(y, window.innerHeight - y),
                );

                const applyTheme = () => {
                    document.documentElement.classList.toggle(
                        "dark",
                        willBeDark,
                    );
                    localStorage.setItem(
                        "theme",
                        willBeDark ? "dark" : "light",
                    );
                    syncThemeIcon(true);
                };

                const reducedMotion = window.matchMedia(
                    "(prefers-reduced-motion: reduce)",
                ).matches;

                if (
                    typeof document.startViewTransition !== "function" ||
                    reducedMotion
                ) {
                    applyTheme();
                    return;
                }

                document.documentElement.setAttribute(
                    "data-theme-switching",
                    "",
                );
                const vt = document.startViewTransition(applyTheme);
                vt.ready
                    .then(() => {
                        document.documentElement.animate(
                            {
                                clipPath: [
                                    `circle(0px at ${x}px ${y}px)`,
                                    `circle(${radius}px at ${x}px ${y}px)`,
                                ],
                            },
                            {
                                duration: window.innerWidth < 768 ? 350 : 500,
                                easing: "cubic-bezier(0.4, 0, 0.2, 1)",
                                pseudoElement: "::view-transition-new(root)",
                            },
                        );
                    })
                    .catch(() => undefined);
                vt.finished.finally(() => {
                    document.documentElement.removeAttribute(
                        "data-theme-switching",
                    );
                });
            });
            themeToggle.dataset.bound = "true";
        }

        document
            .getElementById("toggle-sidebar")
            ?.addEventListener("click", () => {
                if (window.toggleAdminSidebar) {
                    window.toggleAdminSidebar();
                }
            });

        document
            .getElementById("minimize-sidebar")
            ?.addEventListener("click", () => {
                if (window.minimizeAdminSidebar) {
                    window.minimizeAdminSidebar();
                }
            });
    }

    setupNavbar();
    document.addEventListener("astro:page-load", setupNavbar);
</script>
