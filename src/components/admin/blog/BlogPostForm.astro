---
import Dropdown from "../../ui/Dropdown.astro";
import { TextEditor } from "../../ui/TextEditor";

type Props = {
  submitLabel: string;
  submitButtonId?: string;
  statusOptions: { value: string; label: string }[];
  statusValue?: string;
};

const {
  submitLabel,
  submitButtonId = "submit-btn",
  statusOptions,
  statusValue,
} = Astro.props;

const cardClass =
  "rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 p-4 md:p-5";
const titleClass =
  "text-sm font-semibold text-slate-900 dark:text-slate-100 mb-4 border-b border-slate-200 dark:border-slate-700 pb-3";
const labelClass =
  "block text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-widest";
const inputClass =
  "w-full border border-slate-300 dark:border-slate-600 rounded-lg px-4 py-2 text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-slate-400/50 focus:border-slate-400 outline-none transition-all bg-white dark:bg-slate-900/50";
---

<div class="grid grid-cols-1 xl:grid-cols-[minmax(0,1fr)_360px] gap-8">
  <div class="space-y-8">
    <div class={cardClass}>
      <h3 class={titleClass}>Core Content</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-2">
          <label class={labelClass} for="blog-title">Title</label>
          <input
            id="blog-title"
            type="text"
            name="title"
            required
            class={inputClass}
          />
        </div>
        <div class="space-y-2">
          <label class={labelClass} for="blog-slug">Slug</label>
          <input id="blog-slug" type="text" name="slug" class={inputClass} />
        </div>
        <div class="space-y-2 md:col-span-2">
          <label class={labelClass} for="blog-excerpt">Excerpt</label>
          <textarea
            id="blog-excerpt"
            name="excerpt"
            rows="3"
            required
            class={`${inputClass} resize-none`}></textarea>
        </div>
        <div class="space-y-2 md:col-span-2">
          <label class={labelClass} for="blog-hero">Hero Statement</label>
          <textarea
            id="blog-hero"
            name="heroText"
            rows="2"
            class={`${inputClass} resize-none`}></textarea>
        </div>
        <div class="space-y-2 md:col-span-2">
          <label class={labelClass} for="blog-body">Body Content</label>
          <TextEditor
            id="blog-body"
            name="bodyContent"
            content=""
            client:load
          />
        </div>
      </div>
    </div>
  </div>

  <div class="space-y-8">
    <div class={cardClass}>
      <h3 class={titleClass}>Publish Settings</h3>
      <div class="grid grid-cols-1 gap-6">
        <div class="space-y-2">
          <Dropdown
            label="Status"
            name="status"
            options={statusOptions}
            placeholder="Select Status"
            value={statusValue}
          />
        </div>
        <div class="space-y-2">
          <label class={labelClass} for="blog-published-date">
            Published Date
          </label>
          <input
            id="blog-published-date"
            type="date"
            name="publishedDate"
            class={inputClass}
          />
        </div>
        <div class="space-y-2">
          <label class={labelClass} for="blog-category">Category</label>
          <input
            id="blog-category"
            type="text"
            name="category"
            class={inputClass}
          />
        </div>
        <div class="space-y-2">
          <label class={labelClass} for="blog-tags"
            >Tags (comma separated)</label
          >
          <input id="blog-tags" type="text" name="tags" class={inputClass} />
        </div>
        <div class="space-y-2 flex items-center pt-2">
          <label class="relative inline-flex items-center cursor-pointer">
            <input type="checkbox" name="isFeatured" class="sr-only peer" />
            <div
              class="w-11 h-6 bg-slate-700 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-slate-600 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"
            >
            </div>
            <span
              class="ml-3 text-sm font-medium text-slate-500 dark:text-slate-400"
              >Featured Post</span
            >
          </label>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="admin-form-actions">
  <button type="submit" id={submitButtonId} class="admin-btn admin-btn-primary">
    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M5 13l4 4L19 7"></path>
    </svg>
    {submitLabel}
  </button>
</div>
