---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  description: string;
  imageUrl?: string | ImageMetadata;
  imageVariant?: "banner" | "logo" | "width-banner";
  imageLoading?: "lazy" | "eager";
  imageFetchPriority?: "high" | "low" | "auto";
  tags: string[];
  link?: string;
}

const {
  title,
  description,
  imageUrl,
  imageVariant = "banner",
  imageLoading = "lazy",
  imageFetchPriority = "low",
  tags,
  link = "#",
} = Astro.props;

const isStringImage = typeof imageUrl === "string";
const isRemoteImage = isStringImage && imageUrl.startsWith("http");
const imageWidth = imageVariant === "logo" ? 80 : 640;
const imageHeight = imageVariant === "logo" ? 80 : 192;
const slug = link.split("/").pop() || title.toLowerCase().replace(/\s+/g, "-");
---

<div
  class="group relative h-full bg-slate-50 border border-slate-200 rounded-xl overflow-hidden hover:border-slate-300 transition-all duration-200 flex flex-col"
>
  <!-- Image Area -->
  <div
    transition:name={`project-image-${slug}`}
    class="relative h-44 bg-slate-50 overflow-hidden"
  >
    {
      imageUrl ? (
        <div
          class={`absolute inset-0 ${imageVariant === "logo" ? "flex items-center justify-center p-10" : ""}`}
        >
          {imageVariant === "logo" ? (
            !isStringImage ? (
              <Image
                src={imageUrl}
                alt={title}
                width={imageWidth}
                height={imageHeight}
                loading={imageLoading}
                decoding="async"
                fetchpriority={imageFetchPriority}
                class="w-20 h-20 object-contain"
              />
            ) : isRemoteImage ? (
              <Image
                src={imageUrl}
                alt={title}
                width={imageWidth}
                height={imageHeight}
                loading={imageLoading}
                decoding="async"
                fetchpriority={imageFetchPriority}
                class="w-20 h-20 object-contain"
              />
            ) : (
              <img
                src={imageUrl}
                alt={title}
                width={imageWidth}
                height={imageHeight}
                loading={imageLoading}
                decoding="async"
                fetchpriority={imageFetchPriority}
                class="w-20 h-20 object-contain"
              />
            )
          ) : !isStringImage ? (
            <Image
              src={imageUrl}
              alt={title}
              width={imageWidth}
              height={imageHeight}
              loading={imageLoading}
              decoding="async"
              fetchpriority={imageFetchPriority}
              class={`w-full h-full group-hover:scale-105 transition-transform duration-300 ${imageVariant === "width-banner" ? "object-contain p-4" : "object-cover"}`}
            />
          ) : isRemoteImage ? (
            <Image
              src={imageUrl}
              alt={title}
              width={imageWidth}
              height={imageHeight}
              loading={imageLoading}
              decoding="async"
              fetchpriority={imageFetchPriority}
              class={`w-full h-full group-hover:scale-105 transition-transform duration-300 ${imageVariant === "width-banner" ? "object-contain p-4" : "object-cover"}`}
            />
          ) : (
            <img
              src={imageUrl}
              alt={title}
              width={imageWidth}
              height={imageHeight}
              loading={imageLoading}
              decoding="async"
              fetchpriority={imageFetchPriority}
              class={`w-full h-full group-hover:scale-105 transition-transform duration-300 ${imageVariant === "width-banner" ? "object-contain p-4" : "object-cover"}`}
            />
          )}
        </div>
      ) : (
        <div class="absolute inset-0 flex items-center justify-center">
          <svg
            class="w-10 h-10 text-gray-700"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
            />
          </svg>
        </div>
      )
    }
  </div>

  <!-- Content -->
  <div class="p-5 flex flex-col flex-grow">
    <div class="flex items-start justify-between gap-2 mb-2">
      <h3
        transition:name={`project-title-${slug}`}
        class="text-base font-semibold text-slate-900 group-hover:text-blue-400 transition-colors leading-snug"
      >
        {title}
      </h3>
      <svg
        class="w-4 h-4 text-slate-600 group-hover:text-blue-400 transition-colors shrink-0 mt-0.5"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M7 17L17 7M17 7H7M17 7v10"
        />
      </svg>
    </div>

    <p class="text-slate-400 text-sm leading-relaxed mb-4 line-clamp-2 flex-grow">
      {description}
    </p>

    <div class="flex flex-wrap gap-1.5 mt-auto">
      {
        tags
          .slice(0, 3)
          .map((tag) => (
            <span class="px-2 py-0.5 text-xs text-slate-500 bg-slate-100 border border-slate-300 rounded">
              {tag}
            </span>
          ))
      }
      {
        tags.length > 3 && (
          <span class="px-2 py-0.5 text-xs text-slate-400 bg-white border border-slate-200 rounded">
            +{tags.length - 3}
          </span>
        )
      }
    </div>

    <a href={link} class="absolute inset-0 z-10" aria-label={`View ${title}`}></a>
  </div>
</div>
