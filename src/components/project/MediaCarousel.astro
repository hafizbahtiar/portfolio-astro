---
import type { PublicMediaItem } from "../../types/project-cms";

interface Props {
  items: PublicMediaItem[];
  title?: string;
}

const { items, title = "Project media" } = Astro.props;

// Frame wrapper sizing/treatment per device_frame. CSS-only (no frame image assets).
const FRAME: Record<string, string> = {
  phone: "max-w-[280px] rounded-[2rem] border-4 border-slate-800 dark:border-slate-600 bg-slate-800 dark:bg-slate-900 p-1.5",
  tablet: "max-w-[460px] rounded-2xl border-4 border-slate-800 dark:border-slate-600 bg-slate-800 dark:bg-slate-900 p-1.5",
  desktop: "rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 p-1",
  browser: "rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800",
  none: "rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 overflow-hidden",
};
const innerRadius = (f: string) =>
  f === "phone" ? "rounded-[1.6rem]" : f === "tablet" ? "rounded-xl" : "rounded-md";
---

{
  items.length > 0 && (
    <section class="media-carousel mb-8" aria-roledescription="carousel" aria-label={title}>
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-base font-semibold text-slate-900 dark:text-slate-100">Screenshots</h2>
        <div class="flex gap-2">
          <button
            type="button"
            class="carousel-prev inline-flex h-8 w-8 items-center justify-center rounded-lg border border-slate-300 bg-white text-slate-500 hover:text-slate-900 hover:border-slate-400 disabled:opacity-40 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-400 dark:hover:text-slate-100"
            aria-label="Previous"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
          </button>
          <button
            type="button"
            class="carousel-next inline-flex h-8 w-8 items-center justify-center rounded-lg border border-slate-300 bg-white text-slate-500 hover:text-slate-900 hover:border-slate-400 disabled:opacity-40 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-400 dark:hover:text-slate-100"
            aria-label="Next"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          </button>
        </div>
      </div>

      <div
        class="carousel-track flex gap-4 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-2 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-500"
        tabindex="0"
        role="group"
        aria-label={`${title}, use arrow keys to navigate`}
        style="scrollbar-width: thin;"
      >
        {items.map((m, i) => {
          const frame = FRAME[m.deviceFrame] ?? FRAME.none;
          const ratio = m.width && m.height ? `${m.width} / ${m.height}` : "16 / 10";
          return (
            <figure class="carousel-slide snap-start shrink-0 flex flex-col">
              <div class={frame}>
                {m.deviceFrame === "browser" && (
                  <div class="flex items-center gap-1.5 px-3 py-2 border-b border-slate-200 dark:border-slate-700">
                    <span class="h-2.5 w-2.5 rounded-full bg-red-400" />
                    <span class="h-2.5 w-2.5 rounded-full bg-amber-400" />
                    <span class="h-2.5 w-2.5 rounded-full bg-emerald-400" />
                  </div>
                )}
                {m.mediaType === "video" ? (
                  <video
                    controls
                    preload="none"
                    class={`block w-[80vw] sm:w-[440px] h-auto ${innerRadius(m.deviceFrame)}`}
                    style={`aspect-ratio: ${ratio};`}
                    aria-label={m.alt ?? "Project video"}
                  >
                    <source src={m.url} />
                  </video>
                ) : (
                  <img
                    src={m.url}
                    alt={m.alt ?? ""}
                    width={m.width ?? undefined}
                    height={m.height ?? undefined}
                    loading={i === 0 ? "eager" : "lazy"}
                    decoding="async"
                    fetchpriority={i === 0 ? "high" : "auto"}
                    class={`block w-[80vw] sm:w-[440px] h-auto object-contain ${innerRadius(m.deviceFrame)}`}
                    style={`aspect-ratio: ${ratio};`}
                  />
                )}
              </div>
              {m.caption && (
                <figcaption class="mt-2 text-xs text-slate-500 dark:text-slate-400 max-w-[440px]">{m.caption}</figcaption>
              )}
            </figure>
          );
        })}
      </div>
    </section>
  )
}

<script>
  function setupCarousels() {
    document.querySelectorAll<HTMLElement>(".media-carousel").forEach((root) => {
      if (root.dataset.ready === "1") return;
      root.dataset.ready = "1";
      const track = root.querySelector<HTMLElement>(".carousel-track");
      const prev = root.querySelector<HTMLButtonElement>(".carousel-prev");
      const next = root.querySelector<HTMLButtonElement>(".carousel-next");
      if (!track) return;
      const step = () => {
        const slide = track.querySelector<HTMLElement>(".carousel-slide");
        return slide ? slide.getBoundingClientRect().width + 16 : track.clientWidth * 0.8;
      };
      const update = () => {
        const max = track.scrollWidth - track.clientWidth - 4;
        if (prev) prev.disabled = track.scrollLeft <= 4;
        if (next) next.disabled = track.scrollLeft >= max;
      };
      prev?.addEventListener("click", () => track.scrollBy({ left: -step(), behavior: "smooth" }));
      next?.addEventListener("click", () => track.scrollBy({ left: step(), behavior: "smooth" }));
      track.addEventListener("keydown", (e) => {
        if (e.key === "ArrowRight") { e.preventDefault(); track.scrollBy({ left: step(), behavior: "smooth" }); }
        if (e.key === "ArrowLeft") { e.preventDefault(); track.scrollBy({ left: -step(), behavior: "smooth" }); }
        if (e.key === "Home") { e.preventDefault(); track.scrollTo({ left: 0, behavior: "smooth" }); }
        if (e.key === "End") { e.preventDefault(); track.scrollTo({ left: track.scrollWidth, behavior: "smooth" }); }
      });
      track.addEventListener("scroll", update, { passive: true });
      update();
    });
  }
  setupCarousels();
  document.addEventListener("astro:page-load", setupCarousels);
</script>
