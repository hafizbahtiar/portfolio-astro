---
const links = [
    { text: "Projects", href: "/projects", reload: false, spy: "projects" },
    { text: "Skills", href: "/#skills", reload: true, spy: "skills" },
    { text: "Experience", href: "/#experience", reload: true, spy: "experience" },
];
---

<nav
    id="main-nav"
    class="fixed top-0 left-0 w-full z-50 transition-all duration-300 py-5"
>
    <div
        id="nav-container"
        class="container-main flex items-center justify-between transition-all duration-300"
    >
        <a
            href="/"
            data-astro-reload
            class="font-mono text-base font-semibold text-slate-900 dark:text-slate-100 tracking-tight hover:text-cyan-700 dark:hover:text-cyan-400 transition-colors"
        >
            hafiz<span class="text-cyan-600 dark:text-cyan-400">.dev</span>
        </a>

        <div class="flex items-center gap-1.5">
            <!-- Desktop nav links -->
            <div class="hidden md:flex items-center gap-1" id="navbar-default">
                {
                    links.map((link) => (
                        <a
                            href={link.href}
                            data-astro-reload={link.reload ? true : undefined}
                            data-spy={link.spy}
                            class="nav-link relative px-4 py-2 text-sm text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-all"
                        >
                            {link.text}
                            <span class="nav-link-dot absolute left-1/2 -translate-x-1/2 -bottom-0.5 w-1 h-1 rounded-full bg-cyan-500 dark:bg-cyan-400 opacity-0 scale-0 transition-all duration-200" />
                        </a>
                    ))
                }
                <!-- Contact CTA -->
                <a
                    href="/#contact"
                    data-astro-reload
                    data-spy="contact"
                    class="nav-cta ml-1 inline-flex items-center gap-1.5 px-4 py-1.5 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-500 rounded-full shadow-sm shadow-blue-600/25 hover:shadow-blue-600/40 transition-all"
                >
                    <span
                        class="w-1.5 h-1.5 rounded-full bg-emerald-300 animate-pulse"
                    ></span>
                    Contact
                </a>
            </div>

            <!-- Theme toggle -->
            <button
                id="theme-toggle"
                type="button"
                aria-label="Toggle theme"
                class="theme-toggle-btn p-2 text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
            >
                <!-- Sun icon — shown in dark mode -->
                <svg
                    id="theme-sun"
                    class="hidden w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"
                    ></path>
                </svg>
                <!-- Moon icon — shown in light mode -->
                <svg
                    id="theme-moon"
                    class="block w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
                    ></path>
                </svg>
            </button>

            <!-- Hamburger (mobile) -->
            <button
                id="navbar-toggle"
                type="button"
                class="inline-flex items-center p-2 w-9 h-9 justify-center text-slate-500 dark:text-slate-400 rounded-lg md:hidden hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                aria-controls="mobile-menu"
                aria-expanded="false"
            >
                <span class="sr-only">Open main menu</span>
                <svg
                    id="nav-icon-open"
                    class="w-5 h-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
                <svg
                    id="nav-icon-close"
                    class="hidden w-5 h-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        </div>
    </div>

    <!-- Mobile menu -->
    <div
        id="mobile-menu"
        class="md:hidden mx-4 mt-2 rounded-2xl border border-slate-200 dark:border-slate-700 bg-white/97 dark:bg-slate-900/97 backdrop-blur-xl overflow-hidden grid grid-rows-[0fr] opacity-0 -translate-y-1 pointer-events-none transition-all duration-300 ease-out"
    >
        <div class="min-h-0">
            <div class="p-2">
                {
                    links.map((link) => (
                        <a
                            href={link.href}
                            data-astro-reload={link.reload ? true : undefined}
                            class="block px-4 py-3 text-sm rounded-xl text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-slate-100 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                        >
                            {link.text}
                        </a>
                    ))
                }
                <a
                    href="/#contact"
                    data-astro-reload
                    class="block px-4 py-3 text-sm font-semibold rounded-xl text-blue-600 dark:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-500/10 transition-colors"
                >
                    Contact
                </a>
            </div>
            <div
                class="flex items-center justify-between px-6 py-3 border-t border-slate-200 dark:border-slate-700"
            >
                <span
                    class="inline-flex items-center gap-1.5 font-mono text-[11px] uppercase tracking-wider text-slate-400 dark:text-slate-500"
                >
                    <span
                        class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"
                    ></span>
                    Available for work
                </span>
                <a
                    href="mailto:hafiz@hafizbahtiar.com"
                    class="font-mono text-[11px] text-slate-400 dark:text-slate-500 hover:text-cyan-700 dark:hover:text-cyan-400 transition-colors"
                >
                    hafiz@hafizbahtiar.com
                </a>
            </div>
        </div>
    </div>
</nav>

<style>
    nav.floating-nav {
        padding-top: 0;
        padding-bottom: 0;
        top: 1rem;
    }

    nav.floating-nav #nav-container {
        background-color: rgba(248, 250, 252, 0.92);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(148, 163, 184, 0.35);
        border-radius: 9999px;
        padding: 0.5rem 1.25rem;
        /* Match .container-main (860px) so the pill aligns with content */
        max-width: 860px;
        margin-left: auto;
        margin-right: auto;
        box-shadow: 0 8px 30px rgba(15, 23, 42, 0.08);
    }

    html.dark nav.floating-nav #nav-container {
        background-color: rgba(15, 23, 42, 0.92);
        border-color: rgba(51, 65, 85, 0.5);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.35);
    }

    /* Active link (scroll-spy / current page) */
    .nav-link[aria-current] {
        color: var(--color-slate-900, #0f172a);
    }
    html.dark .nav-link[aria-current] {
        color: var(--color-slate-100, #f1f5f9);
    }
    .nav-link[aria-current] .nav-link-dot {
        opacity: 1;
        scale: 1;
    }

    /* Mobile menu open state */
    #mobile-menu.is-open {
        grid-template-rows: 1fr;
        opacity: 1;
        translate: 0 0;
        pointer-events: auto;
    }

    /* Theme toggle button — press feedback */
    .theme-toggle-btn {
        transform-origin: center;
        transition:
            transform 0.15s ease,
            background-color 0.2s,
            color 0.2s;
    }

    .theme-toggle-btn:active {
        transform: scale(0.8);
    }

    /* Icon animations */
    #theme-sun,
    #theme-moon {
        transform-origin: center;
    }

    @keyframes icon-into-dark {
        0% {
            transform: rotate(-60deg) scale(0.3);
            opacity: 0;
        }
        70% {
            transform: rotate(8deg) scale(1.15);
            opacity: 1;
        }
        100% {
            transform: rotate(0deg) scale(1);
            opacity: 1;
        }
    }

    @keyframes icon-into-light {
        0% {
            transform: rotate(60deg) scale(0.3);
            opacity: 0;
        }
        70% {
            transform: rotate(-8deg) scale(1.15);
            opacity: 1;
        }
        100% {
            transform: rotate(0deg) scale(1);
            opacity: 1;
        }
    }

    .icon-anim-sun {
        animation: icon-into-dark 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }
    .icon-anim-moon {
        animation: icon-into-light 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    /* Scope view-transition overrides to theme-switching only, so Astro page
       transitions are not affected. */
    html[data-theme-switching]::view-transition-old(root),
    html[data-theme-switching]::view-transition-new(root) {
        animation: none;
        mix-blend-mode: normal;
    }

    /* Skip view transitions entirely for users who prefer reduced motion */
    @media (prefers-reduced-motion: reduce) {
        html[data-theme-switching]::view-transition-group(*),
        html[data-theme-switching]::view-transition-old(*),
        html[data-theme-switching]::view-transition-new(*) {
            animation: none !important;
        }

        #mobile-menu {
            transition: none;
        }
    }
</style>

<script>
    const initNavbar = () => {
        const nav = document.getElementById("main-nav");
        const toggleBtn = document.getElementById("navbar-toggle");
        const mobileMenu = document.getElementById("mobile-menu");
        const themeToggle = document.getElementById("theme-toggle");
        const sunIcon = document.getElementById("theme-sun");
        const moonIcon = document.getElementById("theme-moon");
        const iconOpen = document.getElementById("nav-icon-open");
        const iconClose = document.getElementById("nav-icon-close");

        if (!nav || !toggleBtn || !mobileMenu) return;

        const existingController = (window as any).__navbarController;
        if (existingController) existingController.abort();

        const controller = new AbortController();
        (window as any).__navbarController = controller;
        const { signal } = controller;

        // ── Mobile menu ──────────────────────────────────────────────
        const setMenu = (open: boolean) => {
            mobileMenu.classList.toggle("is-open", open);
            toggleBtn.setAttribute("aria-expanded", String(open));
            iconOpen?.classList.toggle("hidden", open);
            iconClose?.classList.toggle("hidden", !open);
        };

        toggleBtn.addEventListener(
            "click",
            () => setMenu(!mobileMenu.classList.contains("is-open")),
            { signal },
        );

        document.addEventListener(
            "click",
            (e) => {
                if (
                    !mobileMenu.contains(e.target as Node) &&
                    !toggleBtn.contains(e.target as Node)
                ) {
                    setMenu(false);
                }
            },
            { signal },
        );

        document.addEventListener(
            "keydown",
            (e) => {
                if (e.key === "Escape") setMenu(false);
            },
            { signal },
        );

        mobileMenu.querySelectorAll("a").forEach((link) => {
            link.addEventListener("click", () => setMenu(false), { signal });
        });

        // ── Floating pill on scroll ──────────────────────────────────
        const handleScroll = () => {
            nav.classList.toggle("floating-nav", window.scrollY > 50);
        };
        handleScroll();
        window.addEventListener("scroll", handleScroll, { signal });

        // ── Active link: current page + homepage scroll-spy ──────────
        const spyLinks =
            document.querySelectorAll<HTMLAnchorElement>("[data-spy]");
        const setActive = (key: string | null) => {
            spyLinks.forEach((a) => {
                if (a.dataset.spy === key) {
                    a.setAttribute("aria-current", "true");
                } else {
                    a.removeAttribute("aria-current");
                }
            });
        };

        if (window.location.pathname.startsWith("/projects")) {
            setActive("projects");
        } else if (window.location.pathname === "/") {
            const sections = ["projects", "skills", "experience", "contact"]
                .map((id) => document.getElementById(id))
                .filter((el): el is HTMLElement => el !== null);

            const spyObserver = new IntersectionObserver(
                (entries) => {
                    // Pick the most visible intersecting section.
                    const visible = entries
                        .filter((e) => e.isIntersecting)
                        .sort(
                            (a, b) =>
                                b.intersectionRatio - a.intersectionRatio,
                        )[0];
                    if (visible) {
                        setActive(visible.target.id);
                    } else if (window.scrollY < 200) {
                        setActive(null);
                    }
                },
                { rootMargin: "-25% 0px -55% 0px", threshold: [0, 0.2, 0.5] },
            );
            sections.forEach((s) => spyObserver.observe(s));
            signal.addEventListener("abort", () => spyObserver.disconnect());
        }

        // ── Theme toggle (icon sync + radial view transition) ────────
        const syncThemeIcon = (animate = false) => {
            const isDark = document.documentElement.classList.contains("dark");

            if (!sunIcon || !moonIcon) return;

            if (isDark) {
                moonIcon.classList.add("hidden");
                moonIcon.classList.remove("block", "icon-anim-moon");
                sunIcon.classList.remove("hidden");
                sunIcon.classList.add("block");
                if (animate) {
                    sunIcon.classList.remove("icon-anim-sun");
                    void (sunIcon as HTMLElement).offsetWidth; // force reflow
                    sunIcon.classList.add("icon-anim-sun");
                }
            } else {
                sunIcon.classList.add("hidden");
                sunIcon.classList.remove("block", "icon-anim-sun");
                moonIcon.classList.remove("hidden");
                moonIcon.classList.add("block");
                if (animate) {
                    moonIcon.classList.remove("icon-anim-moon");
                    void (moonIcon as HTMLElement).offsetWidth;
                    moonIcon.classList.add("icon-anim-moon");
                }
            }
        };

        syncThemeIcon();

        if (themeToggle) {
            themeToggle.addEventListener(
                "click",
                () => {
                    const willBeDark =
                        !document.documentElement.classList.contains("dark");

                    // Capture button center for radial origin
                    const rect = themeToggle.getBoundingClientRect();
                    const x = rect.left + rect.width / 2;
                    const y = rect.top + rect.height / 2;
                    const radius = Math.hypot(
                        Math.max(x, window.innerWidth - x),
                        Math.max(y, window.innerHeight - y),
                    );

                    const applyTheme = () => {
                        document.documentElement.classList.toggle(
                            "dark",
                            willBeDark,
                        );
                        localStorage.setItem(
                            "theme",
                            willBeDark ? "dark" : "light",
                        );
                        syncThemeIcon(true);
                    };

                    // Skip animation for browsers without View Transitions API
                    // or when user prefers reduced motion
                    const reducedMotion = window.matchMedia(
                        "(prefers-reduced-motion: reduce)",
                    ).matches;

                    if (
                        typeof document.startViewTransition !== "function" ||
                        reducedMotion
                    ) {
                        applyTheme();
                        return;
                    }

                    // Shorter duration on small (mobile) screens
                    const duration = window.innerWidth < 768 ? 350 : 500;

                    // Scope transition CSS to theme-switch only
                    document.documentElement.setAttribute(
                        "data-theme-switching",
                        "",
                    );
                    const vt = document.startViewTransition(applyTheme);

                    vt.ready
                        .then(() => {
                            document.documentElement.animate(
                                {
                                    clipPath: [
                                        `circle(0px at ${x}px ${y}px)`,
                                        `circle(${radius}px at ${x}px ${y}px)`,
                                    ],
                                },
                                {
                                    duration,
                                    easing: "cubic-bezier(0.4, 0, 0.2, 1)",
                                    pseudoElement:
                                        "::view-transition-new(root)",
                                },
                            );
                        })
                        .catch(() => {
                            // Transition was skipped or interrupted — theme already applied
                        });

                    vt.finished.finally(() => {
                        document.documentElement.removeAttribute(
                            "data-theme-switching",
                        );
                    });
                },
                { signal },
            );
        }

        // Smooth-scroll hash anchors when already on home page
        document
            .querySelectorAll<HTMLAnchorElement>('a[href^="/#"]')
            .forEach((anchor) => {
                anchor.addEventListener(
                    "click",
                    (e) => {
                        if (window.location.pathname === "/") {
                            e.preventDefault();
                            const hash = anchor.getAttribute("href")!.slice(1);
                            document
                                .querySelector(hash)
                                ?.scrollIntoView({ behavior: "smooth" });
                        }
                    },
                    { signal },
                );
            });
    };

    initNavbar();
    document.addEventListener("astro:page-load", initNavbar);
    document.addEventListener("astro:after-swap", initNavbar);
    window.addEventListener("pageshow", (e) => {
        if (e.persisted) initNavbar();
    });
</script>
