---
const links = [
    { text: "About", href: "/#about", reload: true },
    { text: "Projects", href: "/projects", reload: false },
    { text: "Skills", href: "/#skills", reload: true },
    { text: "Contact", href: "/#contact", reload: true },
];
---

<nav
    id="main-nav"
    class="fixed top-0 left-0 w-full z-50 transition-all duration-300 py-5"
>
    <div
        id="nav-container"
        class="container-main flex items-center justify-between transition-all duration-300"
    >
        <a
            href="/"
            data-astro-reload
            class="text-xl font-bold text-slate-900 tracking-tight hover:text-blue-400 transition-colors"
        >
            Hafiz.dev
        </a>

        <button
            id="navbar-toggle"
            type="button"
            class="inline-flex items-center p-2 w-9 h-9 justify-center text-slate-500 rounded-lg md:hidden hover:bg-slate-100 transition-colors"
            aria-controls="navbar-default"
            aria-expanded="false"
        >
            <span class="sr-only">Open main menu</span>
            <svg
                class="w-5 h-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
        </button>

        <div class="hidden md:flex items-center gap-1" id="navbar-default">
            {
                links.map((link) => (
                    <a
                        href={link.href}
                        data-astro-reload={link.reload ? true : undefined}
                        class="px-4 py-2 text-sm text-slate-500 hover:text-slate-900 rounded-lg hover:bg-slate-100 transition-all"
                    >
                        {link.text}
                    </a>
                ))
            }
        </div>
    </div>

    <!-- Mobile menu -->
    <div
        id="mobile-menu"
        class="hidden md:hidden mx-4 mt-2 rounded-xl border border-slate-200 bg-white/97 backdrop-blur-xl overflow-hidden"
    >
        {
            links.map((link) => (
                <a
                    href={link.href}
                    data-astro-reload={link.reload ? true : undefined}
                    class="block px-4 py-3 text-sm text-slate-500 hover:text-slate-900 hover:bg-slate-100 transition-colors"
                >
                    {link.text}
                </a>
            ))
        }
    </div>
</nav>

<style>
    nav.floating-nav {
        padding-top: 0;
        padding-bottom: 0;
        top: 1rem;
    }

    nav.floating-nav #nav-container {
        background-color: rgba(248, 250, 252, 0.92);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(148, 163, 184, 0.35);
        border-radius: 9999px;
        padding: 0.5rem 1.25rem;
        max-width: 794px;
        margin-left: auto;
        margin-right: auto;
    }
</style>

<script>
    const initNavbar = () => {
        const nav = document.getElementById("main-nav");
        const toggleBtn = document.getElementById("navbar-toggle");
        const mobileMenu = document.getElementById("mobile-menu");
        if (!nav || !toggleBtn || !mobileMenu) return;

        const existingController = (window as any).__navbarController;
        if (existingController) existingController.abort();

        const controller = new AbortController();
        (window as any).__navbarController = controller;
        const { signal } = controller;

        const handleScroll = () => {
            nav.classList.toggle("floating-nav", window.scrollY > 50);
        };

        handleScroll();
        window.addEventListener("scroll", handleScroll, { signal });

        toggleBtn.addEventListener(
            "click",
            () => {
                const open = mobileMenu.classList.toggle("hidden");
                toggleBtn.setAttribute("aria-expanded", String(!open));
            },
            { signal },
        );

        document.addEventListener(
            "click",
            (e) => {
                if (
                    !mobileMenu.contains(e.target as Node) &&
                    !toggleBtn.contains(e.target as Node)
                ) {
                    mobileMenu.classList.add("hidden");
                    toggleBtn.setAttribute("aria-expanded", "false");
                }
            },
            { signal },
        );

        mobileMenu.querySelectorAll("a").forEach((link) => {
            link.addEventListener(
                "click",
                () => {
                    mobileMenu.classList.add("hidden");
                },
                { signal },
            );
        });

        // When already on home page, smooth-scroll to anchor instead of full reload.
        // On other pages, data-astro-reload on the link handles cross-page navigation.
        document
            .querySelectorAll<HTMLAnchorElement>('a[href^="/#"]')
            .forEach((anchor) => {
                anchor.addEventListener(
                    "click",
                    (e) => {
                        if (window.location.pathname === "/") {
                            e.preventDefault();
                            const hash = anchor.getAttribute("href")!.slice(1);
                            document
                                .querySelector(hash)
                                ?.scrollIntoView({ behavior: "smooth" });
                        }
                    },
                    { signal },
                );
            });
    };

    initNavbar();
    document.addEventListener("astro:page-load", initNavbar);
    document.addEventListener("astro:after-swap", initNavbar);
    window.addEventListener("pageshow", (e) => {
        if (e.persisted) initNavbar();
    });
</script>
