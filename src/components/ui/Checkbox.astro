---
interface Props {
  label: string;
  name: string;
  checked?: boolean;
  class?: string;
  id?: string;
}

const {
  label,
  name,
  checked = false,
  class: className = "",
  id: inputId = `${name}-checkbox`,
} = Astro.props;
const labelId = `${name}-label`;
---

<div class={`tech-checkbox-container space-y-2 ${className}`} data-name={name}>
  <label
    id={labelId}
    class="block text-sm font-medium text-slate-500 dark:text-slate-400"
    for={inputId}
  >
    {label}
  </label>
  <div class="relative">
    <input
      id={inputId}
      type="checkbox"
      name={name}
      checked={checked}
      class="sr-only"
      aria-labelledby={labelId}
    />
    <button
      type="button"
      class="w-full bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-600 rounded-lg px-4 py-2 text-left text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-blue-500/50 focus:border-blue-500 outline-none transition-all flex justify-between items-center group hover:border-blue-500/50"
      data-trigger="true"
      aria-controls={inputId}
    >
      <span
        class="selected-text text-sm text-slate-600 dark:text-slate-300 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors truncate"
      >
        <span data-off>Spouse links: ON</span>
        <span data-on class="hidden">Spouse links: OFF</span>
      </span>
      <div
        class="flex items-center text-slate-400 dark:text-slate-500 group-hover:text-blue-600 dark:group-hover:text-blue-500 transition-colors"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 12h16"></path>
        </svg>
      </div>
    </button>
  </div>
</div>

<script>
  function setupCheckboxes() {
    const containers = document.querySelectorAll(".tech-checkbox-container");
    containers.forEach((cont) => {
      if (cont.getAttribute("data-initialized") === "true") return;
      cont.setAttribute("data-initialized", "true");
      const input = cont.querySelector("input[type='checkbox']");
      const trigger = cont.querySelector("[data-trigger='true']");
      const textOff = cont.querySelector("[data-off]");
      const textOn = cont.querySelector("[data-on]");
      const updateUI = () => {
        const isChecked =
          input && input instanceof HTMLInputElement ? input.checked : false;
        if (isChecked) {
          textOff && textOff.classList.add("hidden");
          textOn && textOn.classList.remove("hidden");
        } else {
          textOn && textOn.classList.add("hidden");
          textOff && textOff.classList.remove("hidden");
        }
      };
      updateUI();
      trigger &&
        trigger.addEventListener("click", (e) => {
          e.preventDefault();
          const el = input && input instanceof HTMLInputElement ? input : null;
          if (!el) return;
          el.checked = !el.checked;
          updateUI();
          el.dispatchEvent(new Event("change", { bubbles: true }));
        });
    });
  }
  setupCheckboxes();
  (window as Window & { setupCheckboxes?: () => void }).setupCheckboxes =
    setupCheckboxes;
  document.addEventListener("astro:page-load", setupCheckboxes);
  document.addEventListener("DOMContentLoaded", setupCheckboxes);
</script>
