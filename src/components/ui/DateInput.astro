---
interface Props {
  label: string;
  name: string;
  value?: string;
  required?: boolean;
  class?: string;
  id?: string;
  placeholder?: string;
}

const {
  label,
  name,
  value = "",
  required = false,
  class: className = "",
  id: inputId = `${name}-input`,
  placeholder,
} = Astro.props;
---

<div class={`space-y-2 ${className}`}>
  <label
    class="block text-sm font-medium text-slate-500 dark:text-slate-400"
    for={inputId}
  >
    {label}
  </label>
  <input
    id={inputId}
    type="date"
    name={name}
    value={value}
    required={required}
    placeholder={placeholder}
    class="w-full bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-600 rounded-lg px-4 py-2 text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-blue-500/50 focus:border-blue-500 outline-none transition-all text-sm"
  />
</div>
