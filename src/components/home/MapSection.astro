---
import MapCanvas from "./MapCanvas";
import type { Experience } from "../../types/experiences";
import { formatDateRange } from "../../lib/public-content";
import { KL_CENTER } from "../../lib/constants";

interface Props {
  experiences: Experience[];
}

const { experiences } = Astro.props;

const toCoordinate = (value: unknown): number | null => {
  const coordinate = Number(value);
  return Number.isFinite(coordinate) ? coordinate : null;
};

const markers = experiences.flatMap((exp) => {
  const latitude = toCoordinate(exp.latitude);
  const longitude = toCoordinate(exp.longitude);
  if (latitude === null || longitude === null) return [];
  return [
    {
      id: exp.id,
      company: exp.companyName,
      role: exp.role,
      date: formatDateRange(exp),
      latitude,
      longitude,
    },
  ];
});

const mapCenter: [number, number] =
  markers.length > 0
    ? [
        markers.reduce((sum, m) => sum + m.longitude, 0) / markers.length,
        markers.reduce((sum, m) => sum + m.latitude, 0) / markers.length,
      ]
    : KL_CENTER;
---

<section id="experience" class="scroll-offset">
  <div data-reveal>
    <div class="section-label">
      <span class="section-index">04 / Experience</span>
      <span class="section-rule"></span>
    </div>
    <h2 class="section-heading">Where I've shipped</h2>
    <p class="section-sub">
      Five years of production work across Kuala Lumpur — every pin is a place
      I've built software for.
    </p>
  </div>

  <div class="mt-6 grid grid-cols-1 lg:grid-cols-5 gap-4">
    <!-- Timeline -->
    <div class="lg:col-span-3 flex flex-col" data-reveal>
      {
        experiences.map((exp, index) => (
          <button
            type="button"
            class="exp-entry group relative text-left flex gap-4 rounded-xl px-4 py-4 transition-colors hover:bg-slate-100/80 dark:hover:bg-slate-800/60"
            data-marker-id={exp.id}
            aria-pressed={index === 0 ? "true" : "false"}
          >
            <div class="flex flex-col items-center pt-1.5 shrink-0">
              <span
                class={`exp-dot w-2.5 h-2.5 rounded-full ring-4 transition-colors ${
                  exp.isCurrent
                    ? "bg-emerald-500 ring-emerald-500/15"
                    : "bg-slate-300 dark:bg-slate-600 ring-slate-300/20 dark:ring-slate-600/20"
                }`}
              />
              {index < experiences.length - 1 && (
                <span class="w-px flex-1 bg-slate-200 dark:bg-slate-700 mt-2" />
              )}
            </div>
            <div class="flex-1 pb-1 min-w-0">
              <div class="flex items-baseline justify-between gap-3 flex-wrap">
                <h3 class="text-[15px] font-semibold text-slate-900 dark:text-slate-100 leading-snug">
                  {exp.companyName}
                </h3>
                <span class="font-mono text-[11px] text-slate-400 dark:text-slate-500 shrink-0">
                  {formatDateRange(exp)}
                </span>
              </div>
              <p class="text-sm text-cyan-700 dark:text-cyan-400 mt-0.5 font-medium">
                {exp.role}
                {exp.isCurrent && (
                  <span class="ml-2 font-mono text-[10px] uppercase tracking-wider text-emerald-600 dark:text-emerald-400">
                    current
                  </span>
                )}
              </p>
              {exp.description && (
                <p class="text-sm text-slate-500 dark:text-slate-400 mt-1.5 leading-relaxed">
                  {exp.description}
                </p>
              )}
            </div>
          </button>
        ))
      }
    </div>

    <!-- Map -->
    <div class="lg:col-span-2" data-reveal style="--reveal-delay: 100ms">
      <div
        class="lg:sticky lg:top-24 rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800/80 p-2.5"
      >
        <div
          class="h-[260px] lg:h-[420px] w-full overflow-hidden rounded-xl border border-slate-200 dark:border-slate-700"
        >
          <MapCanvas client:only="react" markers={markers} center={mapCenter} />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .exp-entry[aria-pressed="true"] {
    background-color: rgb(241 245 249 / 0.9);
  }
  html.dark .exp-entry[aria-pressed="true"] {
    background-color: rgb(30 41 59 / 0.7);
  }
</style>

<script>
  // Clicking a timeline entry focuses its marker on the map.
  const initExperienceTimeline = () => {
    const entries = document.querySelectorAll<HTMLButtonElement>(".exp-entry");
    if (!entries.length) return;
    entries.forEach((entry) => {
      entry.addEventListener("click", () => {
        entries.forEach((e) => e.setAttribute("aria-pressed", "false"));
        entry.setAttribute("aria-pressed", "true");
        const markerId = Number(entry.dataset.markerId);
        if (!Number.isNaN(markerId)) {
          window.dispatchEvent(
            new CustomEvent("map-focus-marker", { detail: { markerId } }),
          );
        }
      });
    });
  };

  initExperienceTimeline();
  document.addEventListener("astro:page-load", initExperienceTimeline);
</script>
