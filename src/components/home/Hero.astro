---
interface Props {
    projectCount: number;
    yearsExperience: number;
}
const { projectCount, yearsExperience } = Astro.props;
---

<section id="about" class="relative pt-12 pb-14 md:pt-20 md:pb-20 scroll-offset">
    <div class="container-main">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-8 items-center">
            <!-- Intro -->
            <div class="lg:col-span-7 min-w-0 flex flex-col gap-6">
                <p
                    class="hero-stagger font-mono text-xs tracking-[0.18em] uppercase text-slate-500 dark:text-slate-400"
                    style="--stagger-i: 0"
                >
                    <span class="text-cyan-600 dark:text-cyan-400">~</span> Kuala Lumpur, Malaysia
                    <span class="mx-2 text-slate-300 dark:text-slate-600">·</span>
                    <span class="inline-flex items-center gap-1.5">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                        Available for work
                    </span>
                </p>

                <h1
                    class="hero-stagger font-display text-4xl md:text-5xl font-bold text-slate-900 dark:text-slate-50 leading-[1.08] tracking-tight"
                    style="--stagger-i: 1"
                >
                    I build the systems
                    <span
                        class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-600 via-blue-600 to-cyan-600 dark:from-cyan-300 dark:via-blue-400 dark:to-cyan-300"
                        >behind the screens</span
                    > — and the apps in front of them.
                </h1>

                <p
                    class="hero-stagger text-slate-600 dark:text-slate-400 text-base md:text-lg leading-relaxed max-w-xl"
                    style="--stagger-i: 2"
                >
                    Backend &amp; Flutter developer with {yearsExperience}+ years
                    shipping production software: reliable APIs on Node.js and
                    Cloudflare Workers, mobile apps in Flutter, and everything
                    needed to take a product from idea to release.
                </p>

                <div class="hero-stagger flex flex-wrap gap-3" style="--stagger-i: 3">
                    <a
                        href="#projects"
                        class="px-6 py-3 bg-blue-600 text-white font-semibold text-sm rounded-xl hover:bg-blue-500 shadow-lg shadow-blue-600/20 hover:shadow-blue-600/35 hover:-translate-y-0.5 transition-all"
                    >
                        View projects
                    </a>
                    <a
                        href="#contact"
                        class="px-6 py-3 border border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300 text-sm font-semibold rounded-xl hover:border-slate-400 dark:hover:border-slate-400 hover:text-slate-900 dark:hover:text-slate-100 hover:-translate-y-0.5 transition-all"
                    >
                        Get in touch
                    </a>
                    <a
                        href="/docs/hafizbahtiar-resume-4-3.pdf"
                        download="Hafiz-Bahtiar-Resume.pdf"
                        data-resume-download
                        class="inline-flex items-center gap-2 px-6 py-3 border border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300 text-sm font-semibold rounded-xl hover:border-slate-400 dark:hover:border-slate-400 hover:text-slate-900 dark:hover:text-slate-100 hover:-translate-y-0.5 transition-all"
                    >
                        <svg
                            class="w-4 h-4"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            aria-hidden="true"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
                            ></path>
                        </svg>
                        Download Resume
                    </a>
                    <a
                        href="https://github.com/hafizbahtiar"
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label="GitHub profile"
                        class="inline-flex items-center justify-center w-11 h-11 border border-slate-300 dark:border-slate-600 text-slate-500 dark:text-slate-400 rounded-xl hover:border-slate-400 dark:hover:border-slate-400 hover:text-slate-900 dark:hover:text-slate-100 hover:-translate-y-0.5 transition-all"
                    >
                        <svg class="w-4.5 h-4.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path
                                fill-rule="evenodd"
                                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                                clip-rule="evenodd"></path>
                        </svg>
                    </a>
                </div>
            </div>

            <!-- API-response status card — the backend-first signature -->
            <div class="lg:col-span-5 min-w-0 hero-stagger" style="--stagger-i: 4">
                <div
                    class="relative rounded-2xl border border-slate-200 dark:border-slate-700/80 bg-white dark:bg-surface-code shadow-xl shadow-slate-200/50 dark:shadow-black/30 overflow-hidden"
                >
                    <!-- Glow accent -->
                    <div
                        class="absolute -top-16 -right-16 w-48 h-48 bg-cyan-500/10 dark:bg-cyan-400/10 rounded-full blur-3xl pointer-events-none"
                    >
                    </div>
                    <!-- Title bar -->
                    <div
                        class="flex items-center gap-2 px-4 py-3 border-b border-slate-200 dark:border-slate-700/80 bg-slate-50 dark:bg-surface-code-rail"
                    >
                        <span class="w-2.5 h-2.5 rounded-full bg-red-400/80"></span>
                        <span class="w-2.5 h-2.5 rounded-full bg-amber-400/80"></span>
                        <span class="w-2.5 h-2.5 rounded-full bg-emerald-400/80"></span>
                        <span
                            class="ml-2 font-mono text-[11px] text-slate-400 dark:text-slate-500 truncate"
                            >api.hafizbahtiar.com/profile</span
                        >
                    </div>
                    <!-- JSON body -->
                    <pre
                        class="px-5 py-4 font-mono text-xs sm:text-[12.5px] leading-[1.7] text-slate-600 dark:text-slate-400 overflow-x-auto max-w-full"><code><span class="text-slate-400 dark:text-slate-500">{`{`}</span>
  <span class="text-cyan-700 dark:text-cyan-300">"name"</span>: <span class="text-emerald-700 dark:text-emerald-300">"Hafiz Bahtiar"</span>,
  <span class="text-cyan-700 dark:text-cyan-300">"role"</span>: <span class="text-emerald-700 dark:text-emerald-300">"backend_flutter"</span>,
  <span class="text-cyan-700 dark:text-cyan-300">"stack"</span>: [
    <span class="text-emerald-700 dark:text-emerald-300">"APIs"</span>,
    <span class="text-emerald-700 dark:text-emerald-300">"Flutter"</span>,
    <span class="text-emerald-700 dark:text-emerald-300">"Workers"</span>
  ],
  <span class="text-cyan-700 dark:text-cyan-300">"years_exp"</span>: <span class="text-amber-600 dark:text-amber-300">{yearsExperience}</span>,
  <span class="text-cyan-700 dark:text-cyan-300">"projects"</span>: <span class="text-amber-600 dark:text-amber-300">{projectCount}</span>,
  <span class="text-cyan-700 dark:text-cyan-300">"status"</span>: <span class="text-emerald-700 dark:text-emerald-300">"available_for_work"</span>
<span class="text-slate-400 dark:text-slate-500">{`}`}</span></code></pre>
                    <!-- Status line -->
                    <div
                        class="flex items-center gap-2 px-5 pb-4 font-mono text-[11px] text-slate-400 dark:text-slate-500"
                    >
                        <span class="text-emerald-600 dark:text-emerald-400 font-medium">200 OK</span>
                        <span>·</span>
                        <span>23ms</span>
                        <span>·</span>
                        <span>edge: KUL</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    import { API_BASE_URL } from "../../lib/config";

    // Track resume-download clicks. Fire-and-forget: tracking must never block
    // or delay the actual download (a plain static-file link). Re-registers on
    // ClientRouter navigations, guarding against double-binding.
    function setupResumeTracking() {
        const link = document.querySelector(
            "[data-resume-download]",
        ) as HTMLAnchorElement | null;
        if (!link || link.dataset.trackingBound === "1") return;
        link.dataset.trackingBound = "1";

        link.addEventListener("click", () => {
            const url = `${API_BASE_URL}/public/resume-download`;
            // text/plain keeps the beacon a CORS-safelisted request (no
            // preflight). All tracked fields (IP, country, user-agent) are read
            // server-side from request headers — never sent from the client.
            const body = "hero";
            try {
                if (navigator.sendBeacon) {
                    navigator.sendBeacon(
                        url,
                        new Blob([body], { type: "text/plain" }),
                    );
                } else {
                    void fetch(url, {
                        method: "POST",
                        body,
                        keepalive: true,
                    }).catch(() => {});
                }
            } catch {
                /* tracking is best-effort */
            }
        });
    }

    setupResumeTracking();
    document.addEventListener("astro:page-load", setupResumeTracking);
</script>
