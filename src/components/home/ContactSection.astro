---
import PhoneNumberInput from "../ui/PhoneNumberInput";
---

<section id="contact" class="scroll-offset mb-16 md:mb-20">
  <div
    class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl p-5 sm:p-8 md:p-12 text-slate-900 dark:text-slate-100 relative overflow-hidden transition-all duration-500 ease-out will-change-[max-width] mx-auto"
    id="contact-container"
    style="min-height: 320px;"
  >
    <!-- Subtle background glow -->
    <div
      class="absolute top-0 right-0 w-64 h-64 bg-blue-500/5 rounded-full blur-3xl pointer-events-none"
    >
    </div>

    <!-- Hidden scanner beam (kept for JS compatibility, no visible style) -->
    <div
      id="scanner-beam"
      class="absolute top-0 left-0 w-full h-[1px] opacity-0 z-20 pointer-events-none"
    >
    </div>

    <div
      class="relative z-10 max-w-2xl mx-auto h-full flex flex-col justify-center"
    >
      <!-- Initial View -->
      <div
        id="contact-initial"
        class="transition-all duration-500 ease-out transform origin-center text-center"
      >
        <h2
          class="text-2xl sm:text-3xl md:text-4xl font-bold mb-4 tracking-tight text-slate-900 dark:text-slate-100"
        >
          Let's work together
        </h2>
        <p
          class="text-slate-500 dark:text-slate-400 text-base sm:text-lg mb-8 max-w-md mx-auto leading-relaxed"
        >
          Have a project in mind or want to connect? I'd love to hear from you.
        </p>

        <div class="flex flex-col items-center gap-6">
          <button
            id="get-in-touch-btn"
            class="group inline-flex items-center gap-2 px-8 py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition-colors"
          >
            <span>Send a message</span>
            <svg
              class="w-4 h-4 group-hover:translate-x-0.5 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </button>

          <!-- Social Links -->
          <div class="flex gap-5 items-center justify-center" id="social-links">
            <a
              href="https://github.com/hafizbahtiar"
              target="_blank"
              rel="noopener noreferrer"
              class="text-slate-400 dark:text-slate-500 hover:text-slate-900 dark:hover:text-slate-100 transition-colors"
              aria-label="GitHub"
            >
              <svg
                class="w-6 h-6"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                  clip-rule="evenodd"></path>
              </svg>
            </a>
            <a
              href="https://www.linkedin.com/in/hafizbahtiar/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-slate-400 dark:text-slate-500 hover:text-slate-900 dark:hover:text-slate-100 transition-colors"
              aria-label="LinkedIn"
            >
              <svg
                class="w-6 h-6"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                  clip-rule="evenodd"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Contact Form (Hidden by default) -->
      <div
        id="contact-form"
        class="hidden absolute inset-0 w-full h-full flex flex-col justify-center px-4 md:px-0 py-6 md:py-10"
      >
        <div class="w-full max-w-lg mx-auto">
          <div
            id="contact-header"
            class="flex justify-between items-center mb-7 form-item opacity-0 translate-y-4"
          >
            <h2 class="text-xl font-bold text-slate-900 dark:text-slate-100">
              Send a message
            </h2>
            <button
              id="back-to-initial"
              class="text-slate-400 dark:text-slate-500 hover:text-slate-700 dark:hover:text-slate-300 transition-colors p-1.5 hover:bg-slate-100 dark:hover:bg-slate-700 rounded-lg"
            >
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>
          </div>

          <div
            id="form-status"
            class="hidden text-sm text-center p-3 rounded-lg border mb-4"
          >
          </div>

          <!-- Success View -->
          <div
            id="success-view"
            class="hidden flex flex-col items-center justify-center text-center space-y-5"
          >
            <div
              class="w-14 h-14 bg-green-50 border border-green-200 rounded-full flex items-center justify-center"
            >
              <svg
                class="w-7 h-7 text-green-600"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold text-slate-900 mb-1">
                Message sent
              </h3>
              <p class="text-slate-500 text-sm" id="success-message">
                Thanks — I'll get back to you soon.
              </p>
            </div>
            <button
              id="send-another-btn"
              class="px-5 py-2 border border-slate-300 dark:border-slate-600 hover:border-slate-400 dark:hover:border-slate-500 text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-slate-100 rounded-lg transition-colors text-sm"
            >
              Send another
            </button>
          </div>

          <!-- Actual Form -->
          <form class="space-y-5 text-left" id="main-contact-form">
            <div
              class="form-item opacity-0 translate-x-10 transition-all duration-500 delay-100"
            >
              <label
                for="name"
                class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5"
                >Name</label
              >
              <input
                type="text"
                id="name"
                name="name"
                class="w-full bg-slate-100 dark:bg-slate-700 border border-slate-300 dark:border-slate-600 rounded-lg px-3.5 py-2.5 text-slate-900 dark:text-slate-100 text-sm focus:ring-2 focus:ring-blue-500/40 focus:border-blue-500/60 outline-none transition-colors placeholder-slate-400 dark:placeholder-slate-500"
                placeholder="Your name"
                maxlength="256"
              />
            </div>

            <div
              class="form-item opacity-0 -translate-x-10 transition-all duration-500 delay-200"
            >
              <label
                for="email"
                class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5"
                >Email</label
              >
              <input
                type="email"
                id="email"
                name="email"
                class="w-full bg-slate-100 dark:bg-slate-700 border border-slate-300 dark:border-slate-600 rounded-lg px-3.5 py-2.5 text-slate-900 dark:text-slate-100 text-sm focus:ring-2 focus:ring-blue-500/40 focus:border-blue-500/60 outline-none transition-colors placeholder-slate-400 dark:placeholder-slate-500"
                placeholder="you@example.com"
              />
            </div>

            <PhoneNumberInput
              className="opacity-0 translate-x-10 transition-all duration-500 delay-300"
            />

            <div
              class="form-item opacity-0 -translate-x-10 transition-all duration-500 delay-400"
            >
              <label
                for="message"
                class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5"
                >Message</label
              >
              <div class="relative">
                <textarea
                  id="message"
                  name="message"
                  rows="4"
                  class="w-full bg-slate-100 dark:bg-slate-700 border border-slate-300 dark:border-slate-600 rounded-lg px-3.5 py-2.5 text-slate-900 dark:text-slate-100 text-sm focus:ring-2 focus:ring-blue-500/40 focus:border-blue-500/60 outline-none transition-colors resize-none placeholder-slate-400 dark:placeholder-slate-500"
                  placeholder="What's on your mind?"
                  maxlength="2500"></textarea>
                <span
                  class="absolute right-3 bottom-3 text-xs text-slate-500 dark:text-slate-400"
                  >0 / 2500</span
                >
              </div>
            </div>

            <button
              type="submit"
              id="submit-btn"
              class="form-item opacity-0 translate-y-4 w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2.5 px-6 rounded-lg transition-colors relative overflow-hidden group delay-500 flex items-center justify-center gap-2"
            >
              <span
                class="relative z-10 flex items-center justify-center gap-2"
              >
                Send message
                <svg
                  class="w-4 h-4"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                </svg>
              </span>
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .perspective-1000 {
    perspective: 1000px;
  }

  .tech-border-glow {
    border-color: rgba(6, 182, 212, 0.3);
  }

  .contact-form-active {
    border-radius: 16px;
  }

  @media (min-width: 768px) {
    .contact-form-active {
      max-width: 600px;
    }
  }
</style>

<script>
  import { submitContactForm } from "../../lib/contact";

  const initContactSection = () => {
    const getInTouchBtn = document.getElementById("get-in-touch-btn");
    const backBtn = document.getElementById("back-to-initial");
    const initialView = document.getElementById("contact-initial");
    const formView = document.getElementById("contact-form");
    const container = document.getElementById("contact-container");
    const scannerBeam = document.getElementById("scanner-beam");
    const contactHeader = document.getElementById("contact-header");
    const formItems = document.querySelectorAll(".form-item");

    const contactForm = document.getElementById(
      "main-contact-form",
    ) as HTMLFormElement;
    const submitBtn = document.getElementById(
      "submit-btn",
    ) as HTMLButtonElement;
    const statusDiv = document.getElementById("form-status");
    const successView = document.getElementById("success-view");
    const successMessage = document.getElementById("success-message");
    const sendAnotherBtn = document.getElementById("send-another-btn");

    const existingController = (window as any).__contactUplinkController;
    if (existingController) existingController.abort();
    const controller = new AbortController();
    (window as any).__contactUplinkController = controller;
    const { signal } = controller;

    const applyFormWidth = (active: boolean) => {
      if (!container || !formView) return;
      const isDesktop = window.matchMedia("(min-width: 768px)").matches;
      const currentWidth = container.offsetWidth;
      const parentWidth = container.parentElement?.offsetWidth ?? currentWidth;
      const formWidth = formView.offsetWidth;
      const padding = 64;
      const targetWidth =
        active && isDesktop ? formWidth + padding : parentWidth;
      container.style.maxWidth = `${currentWidth}px`;
      container.style.width = "100%";
      requestAnimationFrame(() => {
        container.style.maxWidth = `${targetWidth}px`;
      });
    };

    if (
      getInTouchBtn &&
      backBtn &&
      initialView &&
      formView &&
      container &&
      scannerBeam &&
      contactForm &&
      submitBtn &&
      statusDiv
    ) {
      let initialHeight = container.offsetHeight;
      container.style.height = `${initialHeight}px`;
      const parentWidth =
        container.parentElement?.offsetWidth ?? container.offsetWidth;
      container.style.maxWidth = `${parentWidth}px`;
      container.style.width = "100%";

      getInTouchBtn.addEventListener(
        "click",
        () => {
          initialHeight = container.offsetHeight;
          container.classList.add("tech-border-glow");
          container.classList.add("contact-form-active");

          initialView.style.transform = "scale(0.95) translateY(16px)";
          initialView.style.opacity = "0";

          setTimeout(() => {
            initialView.classList.add("hidden");
            formView.classList.remove("hidden");
            formView.classList.remove("absolute", "inset-0", "h-full");
            const formHeight = formView.offsetHeight + 128;
            container.style.height = `${Math.max(formHeight, 500)}px`;

            setTimeout(() => {
              container.style.height = "auto";
            }, 500);
            requestAnimationFrame(() => {
              applyFormWidth(true);
            });

            setTimeout(() => {
              formItems.forEach((item) => {
                (item as HTMLElement).style.opacity = "1";
                (item as HTMLElement).style.transform = "translate(0, 0)";
              });
            }, 300);

            setTimeout(() => {
              container.classList.remove("tech-border-glow");
            }, 600);
          }, 350);
        },
        { signal },
      );

      backBtn.addEventListener(
        "click",
        () => {
          closeForm();
        },
        { signal },
      );

      function closeForm() {
        formItems.forEach((item) => {
          (item as HTMLElement).style.opacity = "0";
          (item as HTMLElement).style.transform = "translateY(8px)";
        });

        setTimeout(() => {
          if (!formView || !initialView || !container) return;
          const currentHeight = container.offsetHeight;
          container.style.height = `${currentHeight}px`;
          void container.offsetHeight;

          formView.classList.add("hidden");
          formView.classList.add("absolute", "inset-0", "h-full");

          if (successView && !successView.classList.contains("hidden")) {
            successView.classList.add("hidden");
            contactForm?.classList.remove("hidden");
            contactHeader?.classList.remove("hidden");
          }

          initialView.classList.remove("hidden");
          void initialView.offsetWidth;
          initialView.style.transform = "scale(1) translateY(0)";
          initialView.style.opacity = "1";

          container.style.height = `${initialHeight}px`;
          applyFormWidth(false);
          container.classList.remove("contact-form-active");

          setTimeout(() => {
            formItems.forEach((item) => {
              (item as HTMLElement).style.opacity = "";
              (item as HTMLElement).style.transform = "";
            });
            contactForm?.reset();
            if (statusDiv) statusDiv.classList.add("hidden");
          }, 500);
        }, 350);
      }

      if (sendAnotherBtn) {
        sendAnotherBtn.addEventListener(
          "click",
          () => {
            successView?.classList.add("hidden");
            contactForm?.classList.remove("hidden");
            contactHeader?.classList.remove("hidden");
            contactForm?.reset();
            formItems.forEach((item) => {
              (item as HTMLElement).style.opacity = "0";
              (item as HTMLElement).style.transform = "translateY(8px)";
            });
            setTimeout(() => {
              formItems.forEach((item) => {
                (item as HTMLElement).style.opacity = "1";
                (item as HTMLElement).style.transform = "translate(0, 0)";
              });
            }, 100);
          },
          { signal },
        );
      }

      window.addEventListener(
        "resize",
        () => {
          applyFormWidth(container.classList.contains("contact-form-active"));
        },
        { signal },
      );

      const messageInput = document.getElementById(
        "message",
      ) as HTMLTextAreaElement;
      if (messageInput) {
        messageInput.addEventListener(
          "input",
          function () {
            const counter = this.nextElementSibling;
            if (counter) counter.textContent = `${this.value.length} / 2500`;
          },
          { signal },
        );
      }

      contactForm.addEventListener(
        "submit",
        async (e) => {
          e.preventDefault();

          const originalBtnContent = submitBtn.innerHTML;
          statusDiv.classList.add("hidden");
          statusDiv.className =
            "hidden text-sm text-center p-3 rounded-lg border mb-4";

          const formData = new FormData(contactForm);
          const phoneValue = (formData.get("phone") as string)?.trim();
          const data = {
            name: (formData.get("name") as string).trim(),
            email: (formData.get("email") as string).trim(),
            phone: phoneValue ? phoneValue : undefined,
            message: (formData.get("message") as string).trim(),
            source: "FORM",
          };

          if (!data.name || !data.email || !data.message) {
            statusDiv.textContent = "Please fill in all required fields.";
            statusDiv.classList.remove("hidden");
            statusDiv.classList.add(
              "bg-red-50",
              "border-red-200",
              "text-red-600",
            );
            return;
          }

          submitBtn.disabled = true;
          submitBtn.innerHTML = `
          <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          Sending...
        `;

          try {
            const result = await submitContactForm(data);

            if (result.success) {
              contactForm.classList.add("hidden");
              contactHeader?.classList.add("hidden");
              if (successView) {
                successView.classList.remove("hidden");
                if (successMessage) {
                  successMessage.textContent =
                    result.message || "Thanks — I'll get back to you soon.";
                }
              }
              submitBtn.disabled = false;
              submitBtn.innerHTML = originalBtnContent;
            } else {
              throw new Error(result.error || "Failed to send message.");
            }
          } catch (error: any) {
            console.error("Submission error:", error);
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalBtnContent;

            statusDiv.textContent =
              error.message || "Something went wrong. Please try again.";
            statusDiv.classList.remove("hidden");
            statusDiv.classList.add(
              "bg-red-50",
              "border-red-200",
              "text-red-600",
            );
          }
        },
        { signal },
      );
    }
  };

  const bindContactSection = () => {
    initContactSection();
  };

  bindContactSection();
  document.addEventListener("astro:page-load", bindContactSection);
  document.addEventListener("astro:after-swap", bindContactSection);
  window.addEventListener("pageshow", (event) => {
    if (event.persisted) bindContactSection();
  });
</script>
