---
import ResumeDownloadButton from "../ui/ResumeDownloadButton.astro";

// reCAPTCHA v3 (invisible, score-based). This site key is public; keep it
// as a fallback so production contact submissions still work when build-time
// env is absent.
const DEFAULT_RECAPTCHA_SITE_KEY = "6Ldb8RgtAAAAAFgHmhsP9-D0KKlpbO2eIo6iE9CJ";
const recaptchaSiteKey =
  import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY || DEFAULT_RECAPTCHA_SITE_KEY;
---

<section id="contact" class="scroll-offset mb-16 md:mb-20">
  <div data-reveal>
    <div class="section-label">
      <span class="section-index">05 / Contact</span>
      <span class="section-rule"></span>
    </div>
    <h2 class="section-heading">Let's build something reliable</h2>
    <p class="section-sub">
      Have a role, a project, or a system that needs to scale? I usually reply
      within a day.
    </p>
  </div>

  <div
    class="mt-6 rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800/80 overflow-hidden relative"
    data-reveal
  >
    <div
      class="absolute -top-20 -right-20 w-64 h-64 bg-cyan-500/5 dark:bg-cyan-400/5 rounded-full blur-3xl pointer-events-none"
    >
    </div>

    <div class="relative grid grid-cols-1 md:grid-cols-5">
      <!-- Direct channels -->
      <div
        class="md:col-span-2 p-6 sm:p-8 border-b md:border-b-0 md:border-r border-slate-200 dark:border-slate-700 flex flex-col justify-between gap-8"
      >
        <div>
          <p
            class="font-mono text-xs tracking-[0.18em] uppercase text-slate-400 dark:text-slate-500 mb-4"
          >
            Direct
          </p>
          <a
            href="mailto:hafiz@hafizbahtiar.com"
            class="block text-sm font-medium text-slate-800 dark:text-slate-200 hover:text-cyan-700 dark:hover:text-cyan-400 transition-colors break-all"
          >
            hafiz@hafizbahtiar.com
          </a>
          <p class="text-xs text-slate-400 dark:text-slate-500 mt-2">
            Kuala Lumpur, Malaysia (GMT+8)
          </p>
          <ResumeDownloadButton
            source="contact"
            class="mt-5 inline-flex w-full items-center justify-center gap-2 px-4 py-2.5 border border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300 text-sm font-semibold rounded-xl hover:border-slate-400 dark:hover:border-slate-400 hover:text-slate-900 dark:hover:text-slate-100 transition-all"
          />
        </div>

        <div class="flex gap-4">
          <a
            href="https://github.com/hafizbahtiar"
            target="_blank"
            rel="noopener noreferrer"
            class="text-slate-400 dark:text-slate-500 hover:text-slate-900 dark:hover:text-slate-100 transition-colors"
            aria-label="GitHub"
          >
            <svg
              class="w-5 h-5"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                clip-rule="evenodd"></path>
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/in/hafizbahtiar/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-slate-400 dark:text-slate-500 hover:text-slate-900 dark:hover:text-slate-100 transition-colors"
            aria-label="LinkedIn"
          >
            <svg
              class="w-5 h-5"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                clip-rule="evenodd"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Form -->
      <div class="md:col-span-3 p-6 sm:p-8">
        <!-- Success view -->
        <div
          id="contact-success"
          class="hidden flex-col items-center justify-center text-center gap-4 py-10"
        >
          <div
            class="w-12 h-12 bg-emerald-50 dark:bg-emerald-500/10 border border-emerald-200 dark:border-emerald-500/30 rounded-full flex items-center justify-center"
          >
            <svg
              class="w-6 h-6 text-emerald-600 dark:text-emerald-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-bold text-slate-900 dark:text-slate-100">
              Message sent
            </h3>
            <p
              class="text-sm text-slate-500 dark:text-slate-400 mt-1"
              id="contact-success-message"
            >
              Thanks — I'll get back to you soon.
            </p>
          </div>
          <button
            id="contact-send-another"
            type="button"
            class="px-4 py-2 text-sm border border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300 rounded-lg hover:border-slate-400 dark:hover:border-slate-500 transition-colors"
          >
            Send another
          </button>
        </div>

        <form
          id="contact-form"
          class="space-y-4"
          novalidate
          data-recaptcha-site-key={recaptchaSiteKey || undefined}
        >
          <div
            id="contact-status"
            class="hidden text-sm p-3 rounded-lg border border-red-200 dark:border-red-500/30 bg-red-50 dark:bg-red-500/10 text-red-600 dark:text-red-400"
            role="alert"
          >
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label
                for="contact-name"
                class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5"
                >Name</label
              >
              <input
                type="text"
                id="contact-name"
                name="name"
                required
                maxlength="200"
                autocomplete="name"
                placeholder="Your name"
                class="w-full bg-slate-50 dark:bg-slate-700/60 border border-slate-300 dark:border-slate-600 rounded-lg px-3.5 py-2.5 text-slate-900 dark:text-slate-100 text-sm focus:ring-2 focus:ring-cyan-500/40 focus:border-cyan-500/60 outline-none transition-colors placeholder-slate-400 dark:placeholder-slate-500"
              />
            </div>
            <div>
              <label
                for="contact-email"
                class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5"
                >Email</label
              >
              <input
                type="email"
                id="contact-email"
                name="email"
                required
                maxlength="255"
                autocomplete="email"
                placeholder="you@example.com"
                class="w-full bg-slate-50 dark:bg-slate-700/60 border border-slate-300 dark:border-slate-600 rounded-lg px-3.5 py-2.5 text-slate-900 dark:text-slate-100 text-sm focus:ring-2 focus:ring-cyan-500/40 focus:border-cyan-500/60 outline-none transition-colors placeholder-slate-400 dark:placeholder-slate-500"
              />
            </div>
          </div>

          <!-- Honeypot — invisible to people, irresistible to bots -->
          <div class="hidden" aria-hidden="true">
            <label for="contact-company">Company</label>
            <input
              type="text"
              id="contact-company"
              name="company"
              tabindex="-1"
              autocomplete="off"
            />
          </div>

          <div>
            <label
              for="contact-message"
              class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5"
              >Message</label
            >
            <div class="relative">
              <textarea
                id="contact-message"
                name="message"
                rows="5"
                required
                maxlength="2500"
                placeholder="Tell me about your project or role…"
                class="w-full bg-slate-50 dark:bg-slate-700/60 border border-slate-300 dark:border-slate-600 rounded-lg px-3.5 py-2.5 text-slate-900 dark:text-slate-100 text-sm focus:ring-2 focus:ring-cyan-500/40 focus:border-cyan-500/60 outline-none transition-colors resize-none placeholder-slate-400 dark:placeholder-slate-500"
              ></textarea>
              <span
                id="contact-char-count"
                class="absolute right-3 bottom-3 font-mono text-[11px] text-slate-400 dark:text-slate-500"
                >0 / 2500</span
              >
            </div>
          </div>

          <button
            type="submit"
            id="contact-submit"
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-500 text-white font-semibold text-sm py-2.5 px-6 rounded-xl shadow-lg shadow-blue-600/20 hover:shadow-blue-600/35 transition-all disabled:opacity-60 disabled:cursor-not-allowed"
          >
            Send message
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </button>

          {
            recaptchaSiteKey && (
              <p class="text-[11px] leading-relaxed text-slate-400 dark:text-slate-500">
                Protected by reCAPTCHA — the Google{" "}
                <a
                  href="https://policies.google.com/privacy"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="underline hover:text-slate-600 dark:hover:text-slate-300"
                >
                  Privacy Policy
                </a>{" "}
                and{" "}
                <a
                  href="https://policies.google.com/terms"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="underline hover:text-slate-600 dark:hover:text-slate-300"
                >
                  Terms of Service
                </a>{" "}
                apply.
              </p>
            )
          }
        </form>
      </div>
    </div>
  </div>
</section>

{
  // reCAPTCHA v3 — invisible, score-based; a token is fetched per submit.
  recaptchaSiteKey && (
    <script
      is:inline
      src={`https://www.google.com/recaptcha/api.js?render=${recaptchaSiteKey}`}
      async
      defer
    />
  )
}

<script>
  import { submitContactForm } from "../../lib/contact";

  const initContactSection = () => {
    const form = document.getElementById(
      "contact-form",
    ) as HTMLFormElement | null;
    const submitBtn = document.getElementById(
      "contact-submit",
    ) as HTMLButtonElement | null;
    const statusEl = document.getElementById("contact-status");
    const successEl = document.getElementById("contact-success");
    const successMessageEl = document.getElementById("contact-success-message");
    const sendAnotherBtn = document.getElementById("contact-send-another");
    const messageInput = document.getElementById(
      "contact-message",
    ) as HTMLTextAreaElement | null;
    const charCount = document.getElementById("contact-char-count");
    if (!form || !submitBtn) return;

    const recaptchaSiteKey = form.dataset.recaptchaSiteKey || "";

    // v3: fetch a fresh single-use token at submit time. Resolves to ""
    // on any failure so the caller can show a clean error.
    const executeRecaptcha = (): Promise<string> =>
      new Promise((resolve) => {
        const grecaptcha = (window as any).grecaptcha;
        if (!recaptchaSiteKey || !grecaptcha?.execute) {
          resolve("");
          return;
        }
        try {
          grecaptcha.ready(() => {
            grecaptcha
              .execute(recaptchaSiteKey, { action: "contact" })
              .then((token: string) => resolve(token || ""))
              .catch(() => resolve(""));
          });
        } catch {
          resolve("");
        }
      });

    const existingController = (window as any).__contactController;
    if (existingController) existingController.abort();
    const controller = new AbortController();
    (window as any).__contactController = controller;
    const { signal } = controller;

    const showError = (message: string) => {
      if (!statusEl) return;
      statusEl.textContent = message;
      statusEl.classList.remove("hidden");
    };

    messageInput?.addEventListener(
      "input",
      () => {
        if (charCount)
          charCount.textContent = `${messageInput.value.length} / 2500`;
      },
      { signal },
    );

    sendAnotherBtn?.addEventListener(
      "click",
      () => {
        successEl?.classList.add("hidden");
        successEl?.classList.remove("flex");
        form.classList.remove("hidden");
        form.reset();
        if (charCount) charCount.textContent = "0 / 2500";
      },
      { signal },
    );

    form.addEventListener(
      "submit",
      async (e) => {
        e.preventDefault();
        statusEl?.classList.add("hidden");

        const formData = new FormData(form);
        const honeypot = ((formData.get("company") as string) || "").trim();
        const data: {
          name: string;
          email: string;
          message: string;
          source: string;
          recaptchaToken?: string;
        } = {
          name: ((formData.get("name") as string) || "").trim(),
          email: ((formData.get("email") as string) || "").trim(),
          message: ((formData.get("message") as string) || "").trim(),
          source: "FORM",
        };

        if (!data.name || !data.email || !data.message) {
          showError("Please fill in your name, email, and message.");
          return;
        }

        // Bots that fill the hidden field get a quiet success — nothing sent.
        if (honeypot) {
          form.classList.add("hidden");
          successEl?.classList.remove("hidden");
          successEl?.classList.add("flex");
          return;
        }

        const originalContent = submitBtn.innerHTML;
        submitBtn.disabled = true;
        submitBtn.innerHTML = `
          <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          Sending…`;

        try {
          if (recaptchaSiteKey) {
            const token = await executeRecaptcha();
            if (!token) {
              showError(
                "Couldn't run the spam check. Please reload and try again, or email me directly.",
              );
              return;
            }
            data.recaptchaToken = token;
          }

          const result = await submitContactForm(data);
          if (result.success) {
            form.classList.add("hidden");
            successEl?.classList.remove("hidden");
            successEl?.classList.add("flex");
            if (successMessageEl && result.message) {
              successMessageEl.textContent = result.message;
            }
          } else {
            showError(
              result.error || "Something went wrong. Please try again.",
            );
          }
        } catch {
          showError("Something went wrong. Please email me directly instead.");
        } finally {
          submitBtn.disabled = false;
          submitBtn.innerHTML = originalContent;
        }
      },
      { signal },
    );
  };

  initContactSection();
  document.addEventListener("astro:page-load", initContactSection);
</script>
