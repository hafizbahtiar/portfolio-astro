---
export const prerender = false;
import ProjectLayout from "../../layouts/ProjectLayout.astro";
---

<ProjectLayout
  title="Projects - Hafiz Bahtiar"
  description="Explore my portfolio of projects ranging from mobile apps to web applications."
>
  <div class="mb-12 md:mb-16">
    <h1
      class="text-4xl md:text-5xl font-bold mb-4 text-slate-900 dark:text-slate-100 tracking-tight"
    >
      Projects
    </h1>
    <p
      class="text-slate-500 dark:text-slate-400 text-lg leading-relaxed max-w-xl"
    >
      A selection of applications and tools I've built - from mobile apps to
      backend services.
    </p>
    <p
      id="project-count"
      class="hidden text-slate-600 dark:text-slate-400 text-sm mt-3"
    >
    </p>
  </div>

  <!-- Loading state -->
  <div id="projects-loading" class="grid grid-cols-2 gap-5">
    {
      [0, 1, 2, 3, 4, 5].map((i) => (
        <div class="h-64 rounded-xl bg-slate-100 dark:bg-slate-800 animate-pulse border border-slate-200 dark:border-slate-700" />
      ))
    }
  </div>

  <!-- Error state -->
  <div
    id="projects-error"
    class="hidden text-center py-10 rounded-xl border border-red-200 dark:border-red-900/20 bg-red-50 dark:bg-red-900/5"
  >
    <p class="text-red-600 dark:text-red-400 text-sm">
      Failed to load projects. Please try again later.
    </p>
  </div>

  <!-- Empty state -->
  <div
    id="projects-empty"
    class="hidden text-center py-14 rounded-xl border border-slate-200 dark:border-slate-700 border-dashed"
  >
    <p class="text-slate-400 dark:text-slate-500 text-sm">
      No projects yet. Check back soon.
    </p>
  </div>

  <!-- Projects grid -->
  <div id="projects-grid" class="hidden grid grid-cols-2 gap-5"></div>
</ProjectLayout>

<script>
  function buildProjectCard(project: any, index: number, eagerCount: number) {
    const slug =
      project.slug || project.title.toLowerCase().replace(/\s+/g, "-");
    const tags = project.tags || [];
    const tagsHtml =
      tags
        .slice(0, 4)
        .map(
          (tag: string) =>
            `<span class="px-2 py-0.5 text-xs text-slate-500 dark:text-slate-400 bg-slate-100 dark:bg-slate-700 border border-slate-300 dark:border-slate-600 rounded">${escapeHtml(tag)}</span>`,
        )
        .join("") +
      (tags.length > 4
        ? `<span class="px-2 py-0.5 text-xs text-slate-400 dark:text-slate-500 bg-white dark:bg-slate-700 border border-slate-200 dark:border-slate-600 rounded">+${tags.length - 4}</span>`
        : "");

    const loadingAttr =
      index < eagerCount
        ? 'loading="eager" fetchpriority="high"'
        : 'loading="lazy"';
    const imgHtml = project.imageUrl
      ? `<img src="${escapeHtml(project.imageUrl)}" alt="${escapeHtml(project.title)}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" ${loadingAttr} decoding="async" />`
      : `<svg class="w-10 h-10 text-slate-400 dark:text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>`;

    return `
      <a href="/projects/${escapeHtml(slug)}" class="group relative h-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl overflow-hidden hover:border-slate-300 dark:hover:border-slate-600 transition-all duration-200 flex flex-col">
        <div class="relative h-32 sm:h-44 bg-slate-50 dark:bg-slate-700 overflow-hidden">
          <div class="absolute inset-0 flex items-center justify-center">
            ${imgHtml}
          </div>
        </div>
        <div class="p-3 sm:p-5 flex flex-col flex-grow">
          <div class="flex items-start justify-between gap-2 mb-2">
            <h3 class="text-sm sm:text-base font-semibold text-slate-900 dark:text-slate-100 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors leading-snug">${escapeHtml(project.title)}</h3>
            <svg class="w-4 h-4 text-slate-400 dark:text-slate-500 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10" /></svg>
          </div>
          <p class="text-slate-400 dark:text-slate-500 text-xs sm:text-sm leading-relaxed mb-3 sm:mb-4 line-clamp-2 sm:line-clamp-3 flex-grow">${escapeHtml(project.description)}</p>
          <div class="flex flex-wrap gap-1.5 mt-auto">${tagsHtml}</div>
        </div>
      </a>`;
  }

  function escapeHtml(str: string) {
    const div = document.createElement("div");
    div.appendChild(document.createTextNode(str));
    return div.innerHTML;
  }

  async function loadProjects() {
    const loadingEl = document.getElementById("projects-loading");
    const errorEl = document.getElementById("projects-error");
    const emptyEl = document.getElementById("projects-empty");
    const gridEl = document.getElementById("projects-grid");
    const countEl = document.getElementById("project-count");

    try {
      const apiUrl = `${import.meta.env.PUBLIC_API_URL || "https://api.hafizbahtiar.com/api/v1"}`;
      const response = await fetch(`${apiUrl}/projects`);

      if (!response.ok) throw new Error(`HTTP ${response.status}`);

      const json = await response.json();
      const projects = json?.data || [];

      if (loadingEl) loadingEl.classList.add("hidden");

      if (projects.length === 0) {
        if (emptyEl) emptyEl.classList.remove("hidden");
        return;
      }

      if (gridEl) {
        const eagerCount = 3;
        gridEl.innerHTML = projects
          .map((p: any, i: number) => buildProjectCard(p, i, eagerCount))
          .join("");
        gridEl.classList.remove("hidden");
      }

      if (countEl) {
        countEl.textContent = `${projects.length} projects`;
        countEl.classList.remove("hidden");
      }
    } catch {
      if (loadingEl) loadingEl.classList.add("hidden");
      if (errorEl) errorEl.classList.remove("hidden");
    }
  }

  loadProjects();
  document.addEventListener("astro:page-load", loadProjects);
</script>
