---
export const prerender = false;
import ProjectLayout from "../../layouts/ProjectLayout.astro";
import ProjectCard from "../../components/project/ProjectCard.astro";
import { getPublicProjects } from "../../lib/public-content";

const projects = await getPublicProjects();
---

<ProjectLayout
  title="Projects | Hafiz Bahtiar"
  description="Production systems built by Hafiz Bahtiar — marketplaces, government platforms, logistics tooling, and offline-first mobile apps."
>
  <div class="mb-10 md:mb-14">
    <div class="section-label">
      <span class="section-index">Selected Work</span>
      <span class="section-rule"></span>
    </div>
    <h1
      class="font-display text-4xl md:text-5xl font-bold mb-4 text-slate-900 dark:text-slate-100 tracking-tight"
    >
      Projects
    </h1>
    <p
      class="text-slate-500 dark:text-slate-400 text-lg leading-relaxed max-w-xl"
    >
      {projects.length} production systems — from marketplaces and government platforms
      to logistics tooling and offline-first mobile apps.
    </p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    {
      projects.map((project, index) => (
        <div data-reveal style={`--reveal-delay: ${(index % 2) * 80}ms`}>
          <ProjectCard
            title={project.title}
            description={project.description}
            imageUrl={project.imageUrl}
            imageVariant={project.imageVariant}
            imageLoading={index < 2 ? "eager" : "lazy"}
            imageFetchPriority={index < 2 ? "high" : "auto"}
            tags={
              project.technologies?.length
                ? project.technologies
                : (project.tags ?? [])
            }
            link={`/projects/${project.slug}`}
          />
        </div>
      ))
    }
  </div>
</ProjectLayout>
