---
export const prerender = false;
import ProjectLayout from "../../../layouts/ProjectLayout.astro";
import JsonLd from "../../../components/seo/JsonLd.astro";
import { getPublicProjectBySlug } from "../../../lib/public-content";
import { projectsService } from "../../../lib/projects";

const slug = Astro.params.slug ?? "";

let project = null;
let policy = null;
try {
  if (slug) {
    project = await getPublicProjectBySlug(slug);
    policy = await projectsService
      .getProjectPolicyBySlug(slug)
      .catch(() => null);
  }
} catch (err) {
  console.error("Failed to load project", slug, err);
}

if (!project) {
  return Astro.redirect("/404");
}

const formatStatus = (status?: string) => {
  if (!status) return "Completed";
  return status
    .split("-")
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(" ");
};

const capitalize = (s?: string | null) =>
  s ? s.charAt(0).toUpperCase() + s.slice(1) : null;

const metaDescription = project.description || "View project details.";
const siteOrigin = Astro.site ?? new URL(Astro.url.origin);
const canonical = new URL(`/projects/${project.slug}`, siteOrigin).toString();
const ogImageAbs = project.imageUrl
  ? new URL(project.imageUrl, siteOrigin).toString()
  : undefined;

const technologies =
  project.technologies && project.technologies.length > 0
    ? project.technologies
    : (project.tags ?? []);

const metaChips = [
  project.role,
  project.year != null ? String(project.year) : null,
  capitalize(project.projectType),
  formatStatus(project.status),
].filter(Boolean) as string[];

const infoStats = [
  { label: "Role", value: project.role },
  { label: "Year", value: project.year != null ? String(project.year) : null },
  { label: "Type", value: capitalize(project.projectType) },
  { label: "Status", value: formatStatus(project.status) },
].filter((s) => s.value) as { label: string; value: string }[];

const showBanner =
  !!project.imageUrl &&
  (!project.imageVariant ||
    project.imageVariant === "banner" ||
    project.imageVariant === "width-banner");
const showLogo = project.imageVariant === "logo" && !!project.imageUrl;
const showMediaFallback = !showBanner && !showLogo;
const hasLegal = !!(policy?.privacyPolicy || policy?.termsAndConditions);

// CTA strategy (Phase 0 stopgap before the structured project_links model):
// only render Source/Live buttons for links that survived curation. When a
// project exposes no working public link, fall back to a safe contact CTA —
// framed as "request access" for client work.
const hasPublicLinks = !!(project.githubUrl || project.liveUrl);
const isClientWork = project.projectType === "work";
const contactCtaLabel = isClientWork
  ? "Request a walkthrough"
  : "Discuss this project";

const projectSchema = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: project.title,
  description: metaDescription,
  url: canonical,
  image: ogImageAbs,
  dateCreated: project.year != null ? String(project.year) : undefined,
  keywords: (technologies ?? []).join(", "),
  creator: { "@type": "Person", name: "Hafiz Bahtiar" },
};
---

<ProjectLayout
  title={`${project.title} - Hafiz Bahtiar`}
  description={metaDescription}
  image={ogImageAbs}
  imageAlt={project.title}
>
  <JsonLd schema={projectSchema} />

  <div id="project-content">
    <!-- Back -->
    <a
      href="/projects"
      data-astro-reload
      class="inline-flex items-center gap-1.5 text-sm text-slate-400 dark:text-slate-500 hover:text-slate-900 dark:hover:text-slate-100 transition-colors mb-6 group"
    >
      <svg
        class="w-3.5 h-3.5 group-hover:-translate-x-0.5 transition-transform"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M15 19l-7-7 7-7"></path>
      </svg>
      Back to Projects
    </a>

    <!-- Header -->
    <div class="mb-6">
      <h1
        class="text-2xl md:text-3xl font-bold text-slate-900 dark:text-slate-100 leading-snug"
      >
        {project.title}
      </h1>
      <p
        class="text-slate-500 dark:text-slate-400 text-sm md:text-base mt-2 leading-relaxed max-w-2xl"
      >
        {project.description}
      </p>
      <div class="flex flex-wrap gap-2 mt-4">
        {
          metaChips.map((chip: string) => (
            <span class="text-xs text-slate-500 dark:text-slate-400 bg-slate-100 dark:bg-slate-700 border border-slate-300 dark:border-slate-600 rounded-md px-2.5 py-1">
              {chip}
            </span>
          ))
        }
      </div>
      {
        (project.githubUrl || project.liveUrl) && (
          <div class="flex flex-wrap gap-3 mt-4">
            {project.githubUrl && (
              <a
                href={project.githubUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-4 py-2 text-sm text-slate-700 dark:text-slate-300 bg-slate-100 dark:bg-slate-700 border border-slate-300 dark:border-slate-600 rounded-lg hover:border-slate-400 dark:hover:border-slate-500 hover:text-slate-900 dark:hover:text-slate-100 transition-colors"
              >
                <svg
                  class="w-4 h-4"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    fill-rule="evenodd"
                    d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                    clip-rule="evenodd"
                  />
                </svg>
                Source Code
              </a>
            )}
            {project.liveUrl && (
              <a
                href={project.liveUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-4 py-2 text-sm text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-500/10 border border-blue-200 dark:border-blue-800 rounded-lg hover:bg-blue-100 dark:hover:bg-blue-900/30 hover:border-blue-300 transition-colors"
              >
                Live Demo
                <svg
                  class="w-3.5 h-3.5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                  />
                </svg>
              </a>
            )}
          </div>
        )
      }
      {
        !hasPublicLinks && (
          <div class="flex flex-wrap gap-3 mt-4">
            <a
              href="/#contact"
              class="inline-flex items-center gap-2 px-4 py-2 text-sm text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-500/10 border border-blue-200 dark:border-blue-800 rounded-lg hover:bg-blue-100 dark:hover:bg-blue-900/30 hover:border-blue-300 transition-colors"
            >
              {contactCtaLabel}
              <svg
                class="w-3.5 h-3.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M14 5l7 7m0 0l-7 7m7-7H3"
                />
              </svg>
            </a>
          </div>
        )
      }
    </div>

    {
      showBanner && (
        <div class="rounded-xl overflow-hidden border border-slate-200 dark:border-slate-700 mb-6 bg-white dark:bg-slate-800">
          <img
            src={project.imageUrl}
            alt={project.title}
            class="w-full h-44 sm:h-60 object-contain"
            loading="eager"
            decoding="async"
          />
        </div>
      )
    }
    {
      showLogo && (
        <div class="flex justify-center mb-6 p-6 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800">
          <img
            src={project.imageUrl}
            alt={`${project.title} logo`}
            class="h-20 w-auto"
            loading="eager"
          />
        </div>
      )
    }
    {
      showMediaFallback && (
        <div class="flex items-center justify-center mb-6 h-44 sm:h-56 rounded-xl border border-dashed border-slate-300 dark:border-slate-700 bg-slate-50 dark:bg-slate-800/60">
          <div class="flex flex-col items-center gap-2 text-slate-400 dark:text-slate-500">
            <svg
              class="w-9 h-9"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
              />
            </svg>
            <span class="text-xs">Media coming soon</span>
          </div>
        </div>
      )
    }

    <!-- Tabs -->
    <div class="border-b border-slate-200 dark:border-slate-700 mb-6">
      <div class="flex -mb-px overflow-x-auto">
        <button
          class="tab-btn is-active shrink-0 px-4 py-2.5 text-sm font-medium border-b-2 border-blue-500 transition-colors"
          data-tab="overview">Overview</button
        >
        <button
          class="tab-btn shrink-0 px-4 py-2.5 text-sm font-medium border-b-2 border-transparent transition-colors"
          data-tab="tech-stack">Tech Stack</button
        >
      </div>
    </div>

    <!-- Overview tab -->
    <div id="overview" class="tab-content">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2 space-y-6">
          {
            project.features && project.features.length > 0 && (
              <div>
                <h2 class="text-base font-semibold text-slate-900 dark:text-slate-100 mb-3">
                  Features
                </h2>
                <ul class="space-y-2">
                  {project.features.map((feature: string) => (
                    <li class="flex items-start gap-2 text-sm text-slate-500 dark:text-slate-400">
                      <svg
                        class="w-4 h-4 text-blue-500 mt-0.5 shrink-0"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M5 13l4 4L19 7"
                        />
                      </svg>
                      {feature}
                    </li>
                  ))}
                </ul>
              </div>
            )
          }
          {
            hasLegal && (
              <div class="pt-4 border-t border-slate-200 dark:border-slate-700">
                <h2 class="text-xs font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider mb-3">
                  Legal
                </h2>
                <div class="flex flex-wrap gap-3">
                  {policy?.privacyPolicy && (
                    <a
                      href={`/projects/${project.slug}/privacy`}
                      class="inline-flex items-center gap-2 px-4 py-2 text-sm text-slate-700 dark:text-slate-300 bg-slate-100 dark:bg-slate-700 border border-slate-300 dark:border-slate-600 rounded-lg hover:border-slate-400 dark:hover:border-slate-500 hover:text-slate-900 dark:hover:text-slate-100 transition-colors"
                    >
                      Privacy Policy
                    </a>
                  )}
                  {policy?.termsAndConditions && (
                    <a
                      href={`/projects/${project.slug}/terms`}
                      class="inline-flex items-center gap-2 px-4 py-2 text-sm text-slate-700 dark:text-slate-300 bg-slate-100 dark:bg-slate-700 border border-slate-300 dark:border-slate-600 rounded-lg hover:border-slate-400 dark:hover:border-slate-500 hover:text-slate-900 dark:hover:text-slate-100 transition-colors"
                    >
                      Terms &amp; Conditions
                    </a>
                  )}
                </div>
              </div>
            )
          }
        </div>
        <div
          class="rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 p-5 h-fit"
        >
          <h3
            class="text-xs font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider mb-4"
          >
            Project Info
          </h3>
          <div class="space-y-3">
            {
              infoStats.map((stat) => (
                <div class="flex justify-between items-center border-b border-slate-200 dark:border-slate-700 pb-3 last:border-0 last:pb-0">
                  <span class="text-xs text-slate-400 dark:text-slate-500">
                    {stat.label}
                  </span>
                  <span class="text-xs text-slate-700 dark:text-slate-300 font-medium">
                    {stat.value}
                  </span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <!-- Tech stack tab -->
    <div id="tech-stack" class="tab-content hidden">
      {
        technologies.length > 0 ? (
          <div class="flex flex-wrap gap-2">
            {technologies.map((tech: string) => (
              <span class="text-sm text-slate-700 dark:text-slate-300 bg-slate-100 dark:bg-slate-700 border border-slate-300 dark:border-slate-600 rounded-lg px-3 py-1.5">
                {tech}
              </span>
            ))}
          </div>
        ) : (
          <p class="text-slate-400 dark:text-slate-500 text-sm">
            No technologies listed.
          </p>
        )
      }
    </div>
  </div>
</ProjectLayout>

<style>
  .tab-btn {
    color: #94a3b8;
  }
  .tab-btn:hover {
    color: #475569;
  }
  .tab-btn.is-active {
    color: #0f172a;
  }

  html.dark .tab-btn {
    color: #64748b;
  }
  html.dark .tab-btn:hover {
    color: #cbd5e1;
  }
  html.dark .tab-btn.is-active {
    color: #f1f5f9;
  }
</style>

<script>
  function setupTabs() {
    const tabBtns = document.querySelectorAll<HTMLButtonElement>(".tab-btn");
    const tabContents = document.querySelectorAll<HTMLElement>(".tab-content");
    if (!tabBtns.length) return;
    tabBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const tabId = btn.dataset.tab!;
        tabBtns.forEach((b) => {
          b.classList.remove("border-blue-500", "is-active");
          b.classList.add("border-transparent");
        });
        btn.classList.add("border-blue-500", "is-active");
        btn.classList.remove("border-transparent");
        tabContents.forEach((c) => c.classList.add("hidden"));
        document.getElementById(tabId)?.classList.remove("hidden");
      });
    });
  }
  setupTabs();
  document.addEventListener("astro:page-load", setupTabs);
</script>
