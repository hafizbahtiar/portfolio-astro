---
import CoreLayout from "../layouts/CoreLayout.astro";
import Background from "../components/layout/Background.astro";
---

<CoreLayout title="Sign in | Hafiz.dev">
  <Background />
  <div class="min-h-screen flex items-center justify-center p-4">
    <div class="w-full max-w-sm">
      <!-- Header -->
      <div class="mb-8 text-center">
        <div
          class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-blue-500/10 border border-blue-500/20 mb-4"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6 text-blue-400"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
            ></path>
          </svg>
        </div>
        <h1 class="text-2xl font-bold text-slate-900 dark:text-slate-100">
          Sign in
        </h1>
        <p class="text-sm text-slate-400 dark:text-slate-500 mt-1">
          Admin dashboard access
        </p>
      </div>

      <!-- Status message -->
      <div id="status-display" class="mb-4 hidden">
        <div
          id="status-panel"
          class="flex items-center gap-3 px-4 py-3 rounded-lg border text-sm border-red-500/30 bg-red-500/8 text-red-300"
        >
          <div id="status-icon" class="shrink-0">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4"
              viewBox="0 0 20 20"
              fill="currentColor"
            >
              <path
                fill-rule="evenodd"
                d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z"
                clip-rule="evenodd"></path>
            </svg>
          </div>
          <span id="status-text">Invalid email or password.</span>
        </div>
      </div>

      <!-- Login Form -->
      <div
        class="rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 p-6 shadow-xl"
      >
        <form class="space-y-5" id="login-form">
          <div class="space-y-1.5">
            <label
              for="username"
              class="block text-sm font-medium text-slate-700 dark:text-slate-300"
              >Email</label
            >
            <input
              type="text"
              id="username"
              name="username"
              class="block w-full px-3.5 py-2.5 bg-slate-100 dark:bg-slate-700 border border-slate-300 dark:border-slate-600 rounded-lg text-slate-900 dark:text-slate-100 placeholder-slate-400 dark:placeholder-slate-500 focus:ring-2 focus:ring-blue-500/40 focus:border-blue-500/60 transition-colors text-sm"
              placeholder="you@example.com"
              required
            />
          </div>

          <div class="space-y-1.5">
            <label
              for="password"
              class="block text-sm font-medium text-slate-700 dark:text-slate-300"
              >Password</label
            >
            <div class="relative">
              <input
                type="password"
                id="password"
                name="password"
                class="block w-full px-3.5 py-2.5 bg-slate-100 dark:bg-slate-700 border border-slate-300 dark:border-slate-600 rounded-lg text-slate-900 dark:text-slate-100 placeholder-slate-400 dark:placeholder-slate-500 focus:ring-2 focus:ring-blue-500/40 focus:border-blue-500/60 transition-colors text-sm pr-10"
                placeholder="••••••••"
                required
              />
              <button
                type="button"
                id="toggle-password"
                class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-700 transition-colors"
                aria-label="Toggle password visibility"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
                  ></path>
                </svg>
              </button>
            </div>
          </div>

          <button
            type="submit"
            id="submit-btn"
            class="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition-colors text-sm"
          >
            Sign in
          </button>
        </form>
      </div>
    </div>
  </div>
</CoreLayout>

<style>
  .status-panel {
    opacity: 0;
    transform: translateY(-4px);
  }

  #status-display:not(.hidden) .status-panel {
    animation: status-in 0.25s ease forwards;
  }

  .status-success {
    border-color: rgba(16, 185, 129, 0.3) !important;
    background: rgba(16, 185, 129, 0.08) !important;
    color: rgb(167, 243, 208) !important;
  }

  @keyframes status-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  import { authService } from "../lib/auth";

  const form = document.getElementById("login-form") as HTMLFormElement | null;
  const statusDisplay = document.getElementById("status-display");
  const statusText = document.getElementById("status-text");
  const statusPanel = document.getElementById("status-panel");
  const statusIcon = document.getElementById("status-icon");
  const submitBtn = document.getElementById(
    "submit-btn",
  ) as HTMLButtonElement | null;

  let failedAttempts = 0;
  let lockUntil = 0;

  // Toggle Password Visibility
  const togglePasswordBtn = document.getElementById("toggle-password");
  const passwordInput = document.getElementById("password") as HTMLInputElement;

  togglePasswordBtn?.addEventListener("click", () => {
    if (passwordInput) {
      const type =
        passwordInput.getAttribute("type") === "password" ? "text" : "password";
      passwordInput.setAttribute("type", type);

      const svg = togglePasswordBtn.querySelector("svg");
      if (svg) {
        if (type === "text") {
          svg.innerHTML = `
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
          `;
        } else {
          svg.innerHTML = `
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
          `;
        }
      }
    }
  });

  // Redirect if already logged in
  if (authService.isAuthenticated()) {
    window.location.href = "/admin";
  }

  const showStatus = (
    message: string,
    type: "error" | "success",
    iconHtml: string,
  ) => {
    if (!statusDisplay || !statusText || !statusPanel || !statusIcon) return;
    statusText.textContent = message;
    if (type === "success") {
      statusPanel.classList.add("status-success");
    } else {
      statusPanel.classList.remove("status-success");
    }
    statusIcon.innerHTML = iconHtml;
    statusDisplay.classList.remove("hidden");
    void statusDisplay.offsetWidth;
  };

  const errorIcon = `
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
    </svg>`;

  const successIcon = `
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.707a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
    </svg>`;

  const resetUI = () => {
    (form as HTMLFormElement)?.reset();
    if (submitBtn) {
      submitBtn.textContent = "Sign in";
      submitBtn.disabled = false;
    }
    if (statusDisplay) statusDisplay.classList.add("hidden");
  };

  resetUI();
  window.addEventListener("pageshow", resetUI);

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target as HTMLFormElement);
    const email = formData.get("username") as string;
    const password = formData.get("password") as string;

    if (!email || !password) return;

    if (Date.now() < lockUntil) {
      const remaining = Math.ceil((lockUntil - Date.now()) / 1000);
      showStatus(
        `Too many attempts. Try again in ${remaining}s.`,
        "error",
        errorIcon,
      );
      return;
    }

    if (submitBtn) {
      submitBtn.innerHTML = `
        <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        Signing in...
      `;
      submitBtn.disabled = true;
    }

    if (statusDisplay) statusDisplay.classList.add("hidden");

    try {
      const result = await authService.login(email, password);

      if (result) {
        failedAttempts = 0;
        if (submitBtn) {
          submitBtn.innerHTML = `
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            Signed in
          `;
        }
        showStatus("Redirecting to dashboard...", "success", successIcon);
        setTimeout(() => {
          window.location.href = "/admin";
        }, 1000);
      } else {
        throw new Error("Invalid email or password.");
      }
    } catch (error: any) {
      failedAttempts++;
      if (failedAttempts >= 5) {
        lockUntil = Date.now() + 60_000;
        failedAttempts = 0;
      }

      if (submitBtn) {
        submitBtn.textContent = "Sign in";
        submitBtn.disabled = false;
      }

      showStatus(
        error.message || "Invalid email or password.",
        "error",
        errorIcon,
      );
    }
  });
</script>
