---
import PublicLayout from "../../../layouts/PublicLayout.astro";
import {
  getPublicFamilyTreeBySlug,
  getPublicFamilyTrees,
} from "../../../lib/family";
import type { FamilyPerson, FamilyTreeDetail } from "../../../types/family";

export async function getStaticPaths() {
  try {
    const trees = await getPublicFamilyTrees();
    const detailPromises = trees.map((tree) =>
      getPublicFamilyTreeBySlug(tree.slug),
    );
    const details = (await Promise.all(detailPromises)).filter(
      Boolean,
    ) as FamilyTreeDetail[];

    const paths = details.flatMap((detail) =>
      detail.people.map((person) => ({
        params: { id: String(person.id) },
        props: { person, detail },
      })),
    );

    return paths;
  } catch (error) {
    console.error("Failed to build family person paths:", error);
    return [];
  }
}

const { person, detail } = Astro.props as {
  person: FamilyPerson;
  detail: FamilyTreeDetail;
};

const related = detail.relationships.filter(
  (relationship) =>
    relationship.personId === person.id ||
    relationship.relatedPersonId === person.id,
);

const personNameMap = new Map(
  detail.people.map((member) => [member.id, member.displayName]),
);
---

<PublicLayout title={`${person.displayName} - Family`}>
  <section class="container-main py-24 space-y-8">
    <div class="space-y-2">
      <a
        href={`/family/${detail.tree.slug}`}
        class="text-sm text-cyan-400 hover:text-cyan-300 font-mono"
      >
        ← Back to {detail.tree.name}
      </a>
      <h1 class="text-4xl font-bold text-white tracking-tight">
        {person.displayName}
      </h1>
      <p class="text-gray-400">
        {person.gender} · {person.isLiving ? "Living" : "Deceased"}
      </p>
      {person.notes && <p class="text-gray-300 max-w-3xl">{person.notes}</p>}
    </div>

    <div class="rounded-xl border border-gray-800 bg-gray-900/40 p-5">
      <h2 class="text-xl font-semibold text-white mb-4">Relationships</h2>
      {
        related.length === 0 ? (
          <p class="text-sm text-gray-400">
            No relationship records for this person.
          </p>
        ) : (
          <div class="space-y-3">
            {related.map((relationship) => {
              const isLeft = relationship.personId === person.id;
              const otherId = isLeft
                ? relationship.relatedPersonId
                : relationship.personId;
              const direction = isLeft ? "to" : "from";
              return (
                <div class="rounded-lg border border-gray-800 bg-gray-900/50 p-4">
                  <p class="text-white">
                    <span class="text-gray-300">{direction}</span>
                    <span class="mx-2 text-cyan-300 font-mono text-sm">
                      {relationship.relationshipType}
                    </span>
                    <a
                      class="hover:text-cyan-300"
                      href={`/family/person/${otherId}`}
                    >
                      {personNameMap.get(otherId) || otherId}
                    </a>
                  </p>
                </div>
              );
            })}
          </div>
        )
      }
    </div>
  </section>
</PublicLayout>
