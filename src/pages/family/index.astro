---
import PublicLayout from "../../layouts/PublicLayout.astro";
import { CombinedFamilyExplorer } from "../../components/family/CombinedFamilyExplorer";
import { getPublicFamilyTrees } from "../../lib/family";
let trees: Array<{ slug: string; name: string }> = [];
try {
  trees = await getPublicFamilyTrees();
} catch {}
---

<PublicLayout title="Family">
  <section class="container-main py-24 space-y-8">
    <div class="space-y-3">
      <p class="text-cyan-400 font-mono text-sm">~/family</p>
      <h1
        class="text-4xl font-bold text-slate-900 dark:text-slate-100 tracking-tight"
      >
        Big Family (Combined)
      </h1>
      <p class="text-slate-500 dark:text-slate-400 max-w-2xl">
        Combined view of Hafiz, Bahtiar, and Azhari families, centered for full
        ancestry.
      </p>
    </div>

    {
      trees.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {trees.map((t) => (
            <a
              href={`/family/${t.slug}`}
              class="inline-flex items-center rounded-md border border-slate-300 dark:border-slate-600 bg-slate-100 dark:bg-slate-700 px-3 py-2 text-sm text-slate-700 dark:text-slate-300 hover:border-cyan-500/50 hover:text-cyan-600 dark:hover:text-cyan-400 transition-colors"
            >
              {t.name}
            </a>
          ))}
        </div>
      )
    }

    <div class="space-y-6">
      <CombinedFamilyExplorer client:load />
    </div>
  </section>
</PublicLayout>
