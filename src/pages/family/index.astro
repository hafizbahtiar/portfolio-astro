---
export const prerender = false;
import PublicLayout from "../../layouts/PublicLayout.astro";
import { FamilyExplorer } from "../../components/family/FamilyExplorer";
import { COMBINED_FAMILY } from "../../data/family";
import { getPublicFamilyTreeBySlug, getPublicFamilyTrees } from "../../lib/family";
import { mergeFamilyTrees } from "../../lib/family-merge";
import {
  sanitizeFamilyDetailForPublic,
  type PublicFamilyTreeDetail,
} from "../../lib/family-privacy";
import type { FamilyTree, FamilyTreeDetail } from "../../types/family";

let trees: FamilyTree[] = [];
let detail: PublicFamilyTreeDetail | null = null;
let loadError = false;

try {
  trees = await getPublicFamilyTrees();
  const details = (
    await Promise.all(trees.map((tree) => getPublicFamilyTreeBySlug(tree.slug)))
  ).filter((treeDetail): treeDetail is FamilyTreeDetail => treeDetail !== null);
  if (details.length > 0) {
    detail = sanitizeFamilyDetailForPublic(
      mergeFamilyTrees(details, COMBINED_FAMILY),
    );
  }
} catch (error) {
  console.error("Failed to load family data:", error);
  loadError = true;
}
---

<PublicLayout title="Family">
  <section class="container-main py-24 space-y-8">
    <div class="space-y-3">
      <h1 class="text-4xl font-bold text-slate-900 dark:text-slate-100 tracking-tight">
        {COMBINED_FAMILY.name}
      </h1>
      <p class="text-slate-500 dark:text-slate-400 max-w-2xl">
        {COMBINED_FAMILY.description}
      </p>
      {
        trees.length > 0 && (
          <nav
            aria-label="Individual family trees"
            class="flex flex-wrap gap-2 pt-1"
          >
            {trees.map((tree) => (
              <a
                href={`/family/${tree.slug}`}
                class="rounded-md border border-slate-200 px-3 py-2 text-sm text-slate-700 transition-colors hover:border-cyan-500/50 hover:bg-slate-50 hover:text-cyan-600 dark:border-slate-700 dark:text-slate-300 dark:hover:bg-slate-700/50 dark:hover:text-cyan-400"
              >
                {tree.name}
              </a>
            ))}
          </nav>
        )
      }
    </div>

    {
      loadError && (
        <div
          role="alert"
          class="rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-600 dark:border-red-900/20 dark:bg-red-900/5 dark:text-red-400"
        >
          Failed to load family data. Please refresh to try again.
        </div>
      )
    }

    {
      !loadError && !detail && (
        <div class="flex h-[420px] items-center justify-center rounded-xl border border-slate-200 bg-slate-50 text-sm text-slate-500 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-400">
          Family data is not available yet.
        </div>
      )
    }

    {
      detail && (
        <FamilyExplorer
          client:load
          detail={detail}
          ancestryDepth={6}
          progenyDepth={5}
        />
      )
    }
  </section>
</PublicLayout>
