---
import PrivateLayout from "../../../layouts/PrivateLayout.astro";
import AdminPageHeader from "../../../components/admin/AdminPageHeader.astro";
import { BlogPostsTable } from "../../../components/admin/blog/BlogPostsTable";
---

<PrivateLayout title="Manage Blog Posts">
  <div class="space-y-6">
  <AdminPageHeader title="Blog Posts" description="Write, publish, and maintain blog content.">
      <a slot="actions" href="/admin/blog/new" class="admin-btn admin-btn-primary">
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 4v16m8-8H4"></path>
        </svg>
        New Post
      </a>
  </AdminPageHeader>

    <BlogPostsTable client:load />
  </div>
</PrivateLayout>
