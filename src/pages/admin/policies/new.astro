---
import PrivateLayout from "../../../layouts/PrivateLayout.astro";
import { TextEditor } from "../../../components/ui/TextEditor";
import Dropdown from "../../../components/ui/Dropdown.astro";
---

<PrivateLayout title="New Policy">
  <div class="space-y-6">
    <div class="flex flex-wrap justify-between items-center gap-4">
      <div>
        <h1
          class="text-xl md:text-2xl font-bold text-slate-900 dark:text-slate-100"
        >
          New Privacy Policy
        </h1>
        <p class="text-slate-400 dark:text-slate-500 text-xs md:text-sm mt-1">
          Create a new policy document
        </p>
      </div>
      <a
        href="/admin/policies"
        class="inline-flex items-center gap-1.5 rounded-lg border border-slate-300 dark:border-slate-600 px-3 py-1.5 text-xs text-slate-500 dark:text-slate-400 transition-colors hover:border-slate-400 dark:hover:border-slate-500 hover:text-slate-700 dark:hover:text-slate-300"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to list
      </a>
    </div>

    <div
      id="loading-state"
      class="text-center py-12 text-slate-500 dark:text-slate-400"
    >
      Loading projects...
    </div>

    <form id="policy-form" class="space-y-6 hidden">
      <Dropdown
        label="Project"
        name="projectId"
        options={[]}
        placeholder="Select project"
      />

      <div class="space-y-4">
        <div class="flex flex-wrap gap-2" role="tablist">
          <button
            type="button"
            id="policy-tab-privacy"
            role="tab"
            aria-selected="true"
            aria-controls="policy-panel-privacy"
            data-tab="privacy"
            class="inline-flex items-center gap-1.5 rounded-lg border border-slate-400 dark:border-slate-500 px-3 py-1.5 text-xs text-slate-700 dark:text-slate-200 transition-colors hover:border-slate-500 dark:hover:border-slate-400 hover:text-slate-800 dark:hover:text-slate-100"
          >
            Privacy Policy
          </button>
          <button
            type="button"
            id="policy-tab-terms"
            role="tab"
            aria-selected="false"
            aria-controls="policy-panel-terms"
            data-tab="terms"
            class="inline-flex items-center gap-1.5 rounded-lg border border-slate-300 dark:border-slate-600 px-3 py-1.5 text-xs text-slate-500 dark:text-slate-400 transition-colors hover:border-slate-400 dark:hover:border-slate-500 hover:text-slate-700 dark:hover:text-slate-300"
          >
            Terms &amp; Conditions
          </button>
        </div>

        <div
          id="policy-panel-privacy"
          role="tabpanel"
          aria-labelledby="policy-tab-privacy"
          data-tab-panel="privacy"
        >
          <label class="space-y-2 block">
            <span
              class="block text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-widest"
              >Privacy Policy</span
            >
            <TextEditor name="privacyPolicy" content="" client:load />
          </label>
        </div>

        <div
          id="policy-panel-terms"
          role="tabpanel"
          aria-labelledby="policy-tab-terms"
          data-tab-panel="terms"
          class="hidden"
        >
          <label class="space-y-2 block">
            <span
              class="block text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-widest"
              >Terms &amp; Conditions</span
            >
            <TextEditor name="termsAndConditions" content="" client:load />
          </label>
        </div>
      </div>

      <button
        id="submit-btn"
        type="submit"
        class="inline-flex items-center gap-1.5 rounded-lg border border-slate-400 dark:border-slate-500 px-3 py-1.5 text-xs text-slate-700 dark:text-slate-200 transition-colors hover:border-slate-500 dark:hover:border-slate-400 hover:text-slate-800 dark:hover:text-slate-100"
      >
        Save Policy
      </button>
    </form>
  </div>
</PrivateLayout>

<script>
  import { projectsService } from "../../../lib/projects";
  import { setupFormGuard } from "../../../lib/form-guard";

  const form = document.getElementById("policy-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const loadingState = document.getElementById("loading-state");
  const dropdownContainer = document.querySelector(
    '[data-name="projectId"]',
  ) as HTMLElement | null;
  const projectInput = dropdownContainer?.querySelector(
    ".dropdown-input",
  ) as HTMLInputElement | null;
  const dropdownList = dropdownContainer?.querySelector(
    ".dropdown-menu ul",
  ) as HTMLUListElement | null;

  let formGuard: ReturnType<typeof setupFormGuard> | null = null;

  const urlParams = new URLSearchParams(window.location.search);
  const initialProjectId = Number(urlParams.get("projectId"));
  const tabButtons = Array.from(
    document.querySelectorAll<HTMLButtonElement>("[data-tab]"),
  );
  const tabPanels = Array.from(
    document.querySelectorAll<HTMLElement>("[data-tab-panel]"),
  );

  const setActiveTab = (tabId: string) => {
    tabButtons.forEach((button) => {
      const isActive = button.dataset.tab === tabId;
      button.setAttribute("aria-selected", String(isActive));
      button.classList.toggle("text-white", isActive);
      button.classList.toggle("border-blue-500/60", isActive);
      button.classList.toggle("bg-blue-500/10", isActive);
      button.classList.toggle("text-slate-400", !isActive);
      button.classList.toggle("border-slate-800", !isActive);
      button.classList.toggle("hover:text-white", !isActive);
      button.classList.toggle("hover:border-blue-500/40", !isActive);
    });
    tabPanels.forEach((panel) => {
      panel.classList.toggle("hidden", panel.dataset.tabPanel !== tabId);
    });
  };

  tabButtons.forEach((button) => {
    button.addEventListener("click", () => {
      if (!button.dataset.tab) return;
      setActiveTab(button.dataset.tab);
    });
  });

  setActiveTab("privacy");

  async function loadProjects() {
    try {
      const projects = await projectsService.getAdminProjects();
      if (dropdownList) {
        dropdownList.innerHTML = projects
          .map(
            (project) => `
              <li>
                <button
                  type="button"
                  class="dropdown-item w-full text-left px-4 py-2 text-sm text-slate-300 hover:bg-blue-900/20 hover:text-blue-400 transition-colors flex items-center justify-between group"
                  data-value="${project.id}"
                >
                  <span>${project.title}</span>
                  <span class="opacity-0 group-hover:opacity-100 text-blue-500 font-bold">
                    _
                  </span>
                </button>
              </li>
            `,
          )
          .join("");
      }

      (window as Window & { setupDropdowns?: () => void }).setupDropdowns?.();

      if (initialProjectId) {
        if (projectInput) {
          projectInput.value = String(initialProjectId);
          projectInput.dispatchEvent(new Event("change"));
        }
        await loadPolicyForProject(initialProjectId);
      }

      loadingState?.classList.add("hidden");
      form?.classList.remove("hidden");

      if (form) {
        formGuard = setupFormGuard(form);
      }
    } catch (error) {
      alert("Failed to load projects");
      loadingState?.classList.add("hidden");
    }
  }

  async function loadPolicyForProject(projectId: number) {
    if (!projectId) return;
    const policy = await projectsService
      .getAdminProjectPolicyById(projectId)
      .catch(() => null);
    if (!form) return;
    const privacyField = form.elements.namedItem("privacyPolicy");
    const termsField = form.elements.namedItem("termsAndConditions");
    if (privacyField instanceof HTMLTextAreaElement) {
      privacyField.value = policy?.privacyPolicy || "";
      privacyField.dispatchEvent(new Event("change"));
    }
    if (termsField instanceof HTMLTextAreaElement) {
      termsField.value = policy?.termsAndConditions || "";
      termsField.dispatchEvent(new Event("change"));
    }
    formGuard?.updateInitialState();
  }

  projectInput?.addEventListener("change", async () => {
    const selectedId = Number(projectInput.value);
    await loadPolicyForProject(selectedId);
  });

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!submitBtn) return;

    const projectId = Number(projectInput?.value);
    if (!projectId) {
      alert("Please select a project");
      return;
    }

    const originalContent = submitBtn.innerHTML;
    submitBtn.innerHTML = "SAVING...";
    submitBtn.disabled = true;

    const formData = new FormData(form);
    const privacyPolicy = String(formData.get("privacyPolicy") || "").trim();
    const termsAndConditions = String(
      formData.get("termsAndConditions") || "",
    ).trim();

    try {
      const result = await projectsService.upsertProjectPolicy(projectId, {
        privacyPolicy: privacyPolicy || null,
        termsAndConditions: termsAndConditions || null,
      });
      if (result) {
        formGuard?.updateInitialState();
        alert("Policy saved successfully!");
        window.location.href = "/admin/policies";
      } else {
        throw new Error("Failed to save policy");
      }
    } catch (error) {
      console.error(error);
      alert("Failed to save policy. Please try again.");
    } finally {
      submitBtn.innerHTML = originalContent;
      submitBtn.disabled = false;
    }
  });

  loadProjects();
</script>
