---
import PrivateLayout from "../../../layouts/PrivateLayout.astro";
import { PoliciesTable } from "../../../components/admin/policies/PoliciesTable";
---

<PrivateLayout title="Project Policies">
  <div class="space-y-6">
    <div class="flex justify-between items-center">
      <div>
        <h1
          class="text-xl md:text-2xl font-bold text-slate-900 dark:text-slate-100"
          aria-label="Privacy Policies"
        >
          Privacy Policies
        </h1>
        <p class="text-slate-400 dark:text-slate-500 text-xs md:text-sm mt-1">
          Site policies and legal documents
        </p>
      </div>
      <a href="/admin/policies/new" class="admin-btn admin-btn-primary">
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 4v16m8-8H4"></path>
        </svg>
        New Policy
      </a>
    </div>

    <PoliciesTable client:load />
  </div>
</PrivateLayout>
