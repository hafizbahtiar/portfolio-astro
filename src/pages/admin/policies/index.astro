---
import PrivateLayout from "../../../layouts/PrivateLayout.astro";
import AdminPageHeader from "../../../components/admin/AdminPageHeader.astro";
import { PoliciesTable } from "../../../components/admin/policies/PoliciesTable";
---

<PrivateLayout title="Project Policies">
  <div class="space-y-6">
    <AdminPageHeader
      title="Policies"
      description="Privacy policies and terms attached to projects."
    >
      <a
        slot="actions"
        href="/admin/policies/new"
        class="admin-btn admin-btn-primary"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 4v16m8-8H4"></path>
        </svg>
        New Policy
      </a>
    </AdminPageHeader>

    <PoliciesTable client:load />
  </div>
</PrivateLayout>
