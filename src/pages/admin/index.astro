---
import PrivateLayout from "../../layouts/PrivateLayout.astro";
import AdminPageHeader from "../../components/admin/AdminPageHeader.astro";

// Data is fetched client-side (see <script> below): admin endpoints require the
// httpOnly auth cookie, which an SSR fetch on Cloudflare cannot forward.
const cardClass = "admin-card";
---

<PrivateLayout title="Dashboard | Hafiz.dev">
  <AdminPageHeader
    title="Dashboard"
    description="Live overview of your portfolio content and messages"
  />

  <!-- Error banner -->
  <div
    id="dash-error"
    class="hidden mb-6 rounded-lg border border-red-300 dark:border-red-800 bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-300 text-sm px-4 py-3"
  >
    Couldn’t load dashboard data. Please refresh to try again.
  </div>

  <!-- KPI cards -->
  <div
    id="dash-kpis"
    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6 mb-8 transition-opacity duration-300"
    data-loading="true"
  >
    <a
      href="/admin/projects"
      class={`${cardClass} block hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors group`}
    >
      <h3 class="text-slate-500 dark:text-slate-400 text-sm font-medium">
        Projects
      </h3>
      <div class="mt-2 flex items-baseline justify-between">
        <span
          id="kpi-projects"
          class="text-2xl font-bold text-slate-900 dark:text-slate-100 tabular-nums"
          >—</span
        >
        <span
          id="kpi-projects-sub"
          class="text-xs px-2 py-1 rounded-full bg-slate-100 dark:bg-slate-900 text-blue-500 dark:text-blue-400"
          >—</span
        >
      </div>
    </a>

    <a
      href="/admin/contact"
      class={`${cardClass} block hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors group`}
    >
      <h3 class="text-slate-500 dark:text-slate-400 text-sm font-medium">
        Messages
      </h3>
      <div class="mt-2 flex items-baseline justify-between">
        <span
          id="kpi-messages"
          class="text-2xl font-bold text-slate-900 dark:text-slate-100 tabular-nums"
          >—</span
        >
        <span
          id="kpi-messages-sub"
          class="text-xs px-2 py-1 rounded-full bg-slate-100 dark:bg-slate-900 text-yellow-500 dark:text-yellow-400"
          >—</span
        >
      </div>
    </a>

    <a
      href="/admin/blog"
      class={`${cardClass} block hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors group`}
    >
      <h3 class="text-slate-500 dark:text-slate-400 text-sm font-medium">
        Blog Posts
      </h3>
      <div class="mt-2 flex items-baseline justify-between">
        <span
          id="kpi-blog"
          class="text-2xl font-bold text-slate-900 dark:text-slate-100 tabular-nums"
          >—</span
        >
        <span
          class="text-xs px-2 py-1 rounded-full bg-slate-100 dark:bg-slate-900 text-emerald-500 dark:text-emerald-400"
          >total</span
        >
      </div>
    </a>

    <a
      href="/admin/experiences"
      class={`${cardClass} block hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors group`}
    >
      <h3 class="text-slate-500 dark:text-slate-400 text-sm font-medium">
        Experiences
      </h3>
      <div class="mt-2 flex items-baseline justify-between">
        <span
          id="kpi-experiences"
          class="text-2xl font-bold text-slate-900 dark:text-slate-100 tabular-nums"
          >—</span
        >
        <span
          class="text-xs px-2 py-1 rounded-full bg-slate-100 dark:bg-slate-900 text-purple-500 dark:text-purple-400"
          >total</span
        >
      </div>
    </a>

    <div class={cardClass}>
      <h3 class="text-slate-500 dark:text-slate-400 text-sm font-medium">
        Resume Downloads
      </h3>
      <div class="mt-2 flex items-baseline justify-between">
        <span
          id="kpi-resume"
          class="text-2xl font-bold text-slate-900 dark:text-slate-100 tabular-nums"
          >—</span
        >
        <span
          class="text-xs px-2 py-1 rounded-full bg-slate-100 dark:bg-slate-900 text-cyan-500 dark:text-cyan-400"
          >downloads</span
        >
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Contact status breakdown -->
    <div class={cardClass}>
      <h2 class="text-lg font-bold text-slate-900 dark:text-slate-100 mb-1">
        Messages by status
      </h2>
      <p class="text-xs text-slate-400 dark:text-slate-500 mb-5">
        <span id="cs-total" class="tabular-nums">—</span> total
      </p>
      <div class="space-y-4">
        {
          [
            { key: "new", label: "New", color: "bg-blue-500" },
            { key: "read", label: "Read", color: "bg-slate-400" },
            { key: "replied", label: "Replied", color: "bg-emerald-500" },
            { key: "archived", label: "Archived", color: "bg-slate-500" },
          ].map((row) => (
            <div>
              <div class="flex items-center justify-between text-sm mb-1">
                <span class="text-slate-600 dark:text-slate-300">
                  {row.label}
                </span>
                <span
                  id={`cs-${row.key}`}
                  class="text-slate-900 dark:text-slate-100 font-medium tabular-nums"
                >
                  —
                </span>
              </div>
              <div class="h-1.5 w-full bg-slate-200 dark:bg-slate-700 rounded-full overflow-hidden">
                <div
                  id={`csbar-${row.key}`}
                  class={`h-full ${row.color} rounded-full transition-all duration-500`}
                  style="width: 0%"
                />
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Recent activity: projects + messages -->
    <div class={`${cardClass} lg:col-span-2`}>
      <h2 class="text-lg font-bold text-slate-900 dark:text-slate-100 mb-5">
        Recent activity
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <div class="flex items-center justify-between mb-3">
            <h3
              class="text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wide"
            >
              Projects
            </h3>
            <a
              href="/admin/projects"
              class="text-xs text-blue-500 dark:text-blue-400 hover:underline"
              >View all</a
            >
          </div>
          <ul id="recent-projects" class="space-y-2">
            <li class="text-sm text-slate-400 dark:text-slate-500">Loading…</li>
          </ul>
        </div>
        <div>
          <div class="flex items-center justify-between mb-3">
            <h3
              class="text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wide"
            >
              Messages
            </h3>
            <a
              href="/admin/contact"
              class="text-xs text-blue-500 dark:text-blue-400 hover:underline"
              >View all</a
            >
          </div>
          <ul id="recent-messages" class="space-y-2">
            <li class="text-sm text-slate-400 dark:text-slate-500">Loading…</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div class={`${cardClass} mt-8`}>
    <h2 class="text-lg font-bold text-slate-900 dark:text-slate-100 mb-1">
      Recent resume downloads
    </h2>
    <p class="text-xs text-slate-400 dark:text-slate-500 mb-5">
      Most recent download clicks · time, IP, country, device
    </p>
    <ul id="recent-downloads" class="space-y-2">
      <li class="text-sm text-slate-400 dark:text-slate-500">Loading…</li>
    </ul>
  </div>
</PrivateLayout>

<script>
  import { dashboardService } from "../../lib/dashboard";
  import type {
    DashboardOverview,
    DashboardRecentProject,
    DashboardRecentContact,
    DashboardRecentDownload,
  } from "../../lib/dashboard";

  function timeAgo(iso: string): string {
    const t = new Date(iso).getTime();
    if (Number.isNaN(t)) return "";
    const s = Math.floor((Date.now() - t) / 1000);
    if (s < 60) return "just now";
    const m = Math.floor(s / 60);
    if (m < 60) return `${m}m ago`;
    const h = Math.floor(m / 60);
    if (h < 24) return `${h}h ago`;
    const d = Math.floor(h / 24);
    if (d < 30) return `${d}d ago`;
    const mo = Math.floor(d / 30);
    if (mo < 12) return `${mo}mo ago`;
    return `${Math.floor(mo / 12)}y ago`;
  }

  function setText(id: string, value: string | number) {
    const el = document.getElementById(id);
    if (el) el.textContent = String(value);
  }

  const CONTACT_BADGE: Record<string, string> = {
    NEW: "text-blue-500 dark:text-blue-400",
    READ: "text-slate-500 dark:text-slate-400",
    REPLIED: "text-emerald-500 dark:text-emerald-400",
    ARCHIVED: "text-slate-400 dark:text-slate-500",
  };

  // Build list rows with textContent only — contact name/subject are
  // attacker-controlled (public contact form), so never use innerHTML here.
  function renderProjects(list: DashboardRecentProject[]) {
    const ul = document.getElementById("recent-projects");
    if (!ul) return;
    ul.replaceChildren();
    if (!list.length) {
      const li = document.createElement("li");
      li.className = "text-sm text-slate-400 dark:text-slate-500";
      li.textContent = "No projects yet.";
      ul.appendChild(li);
      return;
    }
    for (const p of list) {
      const li = document.createElement("li");
      const a = document.createElement("a");
      a.href = `/admin/projects`;
      a.className =
        "flex items-center justify-between gap-3 rounded-lg px-2 py-1.5 -mx-2 hover:bg-slate-50 dark:hover:bg-slate-700/40 transition-colors";
      const title = document.createElement("span");
      title.className = "text-sm text-slate-700 dark:text-slate-200 truncate";
      title.textContent = p.title;
      const when = document.createElement("span");
      when.className = "text-xs text-slate-400 dark:text-slate-500 shrink-0";
      when.textContent = timeAgo(p.updatedAt);
      a.append(title, when);
      li.appendChild(a);
      ul.appendChild(li);
    }
  }

  function renderMessages(list: DashboardRecentContact[]) {
    const ul = document.getElementById("recent-messages");
    if (!ul) return;
    ul.replaceChildren();
    if (!list.length) {
      const li = document.createElement("li");
      li.className = "text-sm text-slate-400 dark:text-slate-500";
      li.textContent = "No messages yet.";
      ul.appendChild(li);
      return;
    }
    for (const m of list) {
      const li = document.createElement("li");
      const a = document.createElement("a");
      a.href = `/admin/contact`;
      a.className =
        "block rounded-lg px-2 py-1.5 -mx-2 hover:bg-slate-50 dark:hover:bg-slate-700/40 transition-colors";

      const top = document.createElement("div");
      top.className = "flex items-center justify-between gap-3";
      const name = document.createElement("span");
      name.className =
        "text-sm font-medium text-slate-700 dark:text-slate-200 truncate";
      name.textContent = m.name;
      const status = document.createElement("span");
      status.className = `text-[11px] shrink-0 ${CONTACT_BADGE[m.status] ?? CONTACT_BADGE.READ}`;
      status.textContent = m.status.toLowerCase();
      top.append(name, status);

      const sub = document.createElement("div");
      sub.className = "flex items-center justify-between gap-3";
      const subject = document.createElement("span");
      subject.className = "text-xs text-slate-500 dark:text-slate-400 truncate";
      subject.textContent = m.subject;
      const when = document.createElement("span");
      when.className = "text-xs text-slate-400 dark:text-slate-500 shrink-0";
      when.textContent = timeAgo(m.createdAt);
      sub.append(subject, when);

      a.append(top, sub);
      li.appendChild(a);
      ul.appendChild(li);
    }
  }

  // Best-effort 2-letter country code → flag emoji (regional indicators).
  function countryFlag(code: string | null): string {
    if (!code || !/^[A-Za-z]{2}$/.test(code)) return code ?? "";
    const cc = code.toUpperCase();
    return String.fromCodePoint(
      0x1f1e6 + cc.charCodeAt(0) - 65,
      0x1f1e6 + cc.charCodeAt(1) - 65,
    );
  }

  // Best-effort "Browser/OS" label from a user-agent string (display only).
  function shortDevice(ua: string): string {
    if (!ua) return "Unknown";
    const browser = /Edg/.test(ua)
      ? "Edge"
      : /OPR|Opera/.test(ua)
        ? "Opera"
        : /Chrome/.test(ua)
          ? "Chrome"
          : /Firefox/.test(ua)
            ? "Firefox"
            : /Safari/.test(ua)
              ? "Safari"
              : "Browser";
    const os = /Windows/.test(ua)
      ? "Windows"
      : /Android/.test(ua)
        ? "Android"
        : /iPhone|iPad|iOS/.test(ua)
          ? "iOS"
          : /Mac OS X|Macintosh/.test(ua)
            ? "Mac"
            : /Linux/.test(ua)
              ? "Linux"
              : "";
    return os ? `${browser}/${os}` : browser;
  }

  // textContent only — ipAddress/userAgent/country originate from request
  // headers an attacker fully controls, so never use innerHTML here.
  function renderDownloads(list: DashboardRecentDownload[]) {
    const ul = document.getElementById("recent-downloads");
    if (!ul) return;
    ul.replaceChildren();
    if (!list.length) {
      const li = document.createElement("li");
      li.className = "text-sm text-slate-400 dark:text-slate-500";
      li.textContent = "No downloads yet.";
      ul.appendChild(li);
      return;
    }
    for (const d of list) {
      const li = document.createElement("li");

      const top = document.createElement("div");
      top.className = "flex items-center justify-between gap-3";
      const ip = document.createElement("span");
      ip.className =
        "text-sm font-mono text-slate-700 dark:text-slate-200 truncate";
      ip.textContent = d.ipAddress || "unknown";
      const when = document.createElement("span");
      when.className = "text-xs text-slate-400 dark:text-slate-500 shrink-0";
      when.textContent = timeAgo(d.createdAt);
      top.append(ip, when);

      const meta = document.createElement("div");
      meta.className = "text-xs text-slate-500 dark:text-slate-400 truncate";
      meta.textContent = [countryFlag(d.country), shortDevice(d.userAgent)]
        .filter(Boolean)
        .join(" · ");

      li.append(top, meta);
      ul.appendChild(li);
    }
  }

  function paint(data: DashboardOverview) {
    // KPI cards
    setText("kpi-projects", data.projects.total);
    setText("kpi-projects-sub", `${data.projects.featured} featured`);
    setText("kpi-messages", data.contacts.total);
    setText("kpi-messages-sub", `${data.contacts.new} new`);
    setText("kpi-blog", data.blog.total);
    setText("kpi-experiences", data.experiences.total);
    setText("kpi-resume", data.resumeDownloads?.total ?? 0);

    // Contact status breakdown
    const s = data.contacts.stats;
    setText("cs-total", s.total);
    const denom = s.total || 1;
    for (const key of ["new", "read", "replied", "archived"] as const) {
      setText(`cs-${key}`, s[key]);
      const bar = document.getElementById(`csbar-${key}`);
      if (bar) bar.style.width = `${Math.round((s[key] / denom) * 100)}%`;
    }

    renderProjects(data.projects.recent ?? []);
    renderMessages(data.contacts.recent ?? []);
    renderDownloads(data.resumeDownloads?.recent ?? []);
  }

  async function loadDashboard() {
    // Only run on the dashboard page (script persists across ClientRouter nav).
    if (!document.getElementById("dash-kpis")) return;

    const errorEl = document.getElementById("dash-error");
    errorEl?.classList.add("hidden");

    try {
      const data = await dashboardService.getOverview();
      // getOverview() returns null on 401 (ApiClient redirects to /login itself).
      if (!data) return;
      paint(data);
      document.getElementById("dash-kpis")?.removeAttribute("data-loading");
    } catch (err) {
      console.error("Dashboard load failed:", err);
      errorEl?.classList.remove("hidden");
    }
  }

  document.addEventListener("astro:page-load", loadDashboard);
</script>
