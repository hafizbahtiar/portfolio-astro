---
import PrivateLayout from "../../../layouts/PrivateLayout.astro";
import { FamilyTreesTable } from "../../../components/admin/family/FamilyTreesTable";
---

<PrivateLayout title="Manage Family Trees">
  <div class="space-y-6">
    <div class="flex justify-between items-center">
      <div>
        <h1 class="text-xl md:text-2xl font-bold text-slate-900 dark:text-slate-100">Family Trees</h1>
        <p class="text-slate-400 dark:text-slate-500 text-xs md:text-sm mt-1">Family tree members and relationships</p>
      </div>
      <a
        href="/admin/family/new"
        class="inline-flex items-center gap-1.5 rounded-lg border border-slate-400 dark:border-slate-500 px-3 py-1.5 text-xs text-slate-700 dark:text-slate-200 transition-colors hover:border-slate-500 dark:hover:border-slate-400 hover:text-slate-800 dark:hover:text-slate-100"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 4v16m8-8H4"></path>
        </svg>
        New Family Tree
      </a>
    </div>

    <FamilyTreesTable client:load />
  </div>
</PrivateLayout>
