---
import PrivateLayout from "../../../layouts/PrivateLayout.astro";
import AdminPageHeader from "../../../components/admin/AdminPageHeader.astro";
import { FamilyTreesTable } from "../../../components/admin/family/FamilyTreesTable";
---

<PrivateLayout title="Manage Family Trees">
  <div class="space-y-6">
  <AdminPageHeader
    title="Family Trees"
    description="Manage family trees, their members, and public visibility."
  >
      <a
        slot="actions"
        href="/admin/family/new" class="admin-btn admin-btn-primary">
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 4v16m8-8H4"></path>
        </svg>
        New Family Tree
      </a>
  </AdminPageHeader>

    <FamilyTreesTable client:load />
  </div>
</PrivateLayout>
