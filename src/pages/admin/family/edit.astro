---
import PrivateLayout from "../../../layouts/PrivateLayout.astro";
import AdminPageHeader from "../../../components/admin/AdminPageHeader.astro";
import { FamilyTreeBuilder } from "../../../components/admin/family/FamilyTreeBuilder";
import AlertToast from "../../../components/ui/AlertToast.astro";
---

<PrivateLayout title="Edit Family Tree">
  <div class="space-y-6">
    <AdminPageHeader
      title="Edit Family Tree"
      description="Edit family member details"
    >
      <a
        slot="actions"
        href="/admin/family"
        class="admin-btn admin-btn-secondary"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to list
      </a>
    </AdminPageHeader>

    <FamilyTreeBuilder client:load mode="edit" />
  </div>
  <AlertToast id="family-builder-alert" />
</PrivateLayout>
