---
import PrivateLayout from "../../../layouts/PrivateLayout.astro";
import { FamilyTreeBuilder } from "../../../components/admin/family/FamilyTreeBuilder";
import AlertToast from "../../../components/ui/AlertToast.astro";
---

<PrivateLayout title="Edit Family Tree">
  <div class="space-y-6">
    <div class="flex justify-between items-center">
      <h1 class="text-3xl font-bold text-white tracking-tight">
        Edit Family Tree
      </h1>
      <a
        href="/admin/family"
        class="text-gray-400 hover:text-white transition-colors flex items-center gap-2"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        BACK TO LIST
      </a>
    </div>

    <FamilyTreeBuilder client:load mode="edit" />
  </div>
  <AlertToast id="family-builder-alert" />
</PrivateLayout>
