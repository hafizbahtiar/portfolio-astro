---
import PrivateLayout from "../../../layouts/PrivateLayout.astro";
import AdminPageHeader from "../../../components/admin/AdminPageHeader.astro";
import AlertToast from "../../../components/ui/AlertToast.astro";
import { ProjectEditor } from "../../../components/admin/projects/ProjectEditor";
---

<PrivateLayout title="New Project">
  <div class="space-y-6">
    <AdminPageHeader
      title="New Project"
      description="Create a draft. Case study, media, tech, links and publishing unlock after it's created."
    >
      <a
        slot="actions"
        href="/admin/projects"
        class="admin-btn admin-btn-secondary"
      >
        Back to list
      </a>
    </AdminPageHeader>

    <ProjectEditor client:load />
  </div>
  <AlertToast id="admin-alert" />
</PrivateLayout>
