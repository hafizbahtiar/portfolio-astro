---
import PrivateLayout from "../../../layouts/PrivateLayout.astro";
import AdminPageHeader from "../../../components/admin/AdminPageHeader.astro";
import { ProjectsTable } from "../../../components/admin/projects/ProjectsTable";
---

<PrivateLayout title="Manage Projects">
  <div class="space-y-6">
    <AdminPageHeader
      title="Projects"
      description="Manage portfolio projects, visibility, ordering, and status."
    >
      <a
        slot="actions"
        href="/admin/projects/new"
        class="admin-btn admin-btn-primary"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 4v16m8-8H4"></path>
        </svg>
        New Project
      </a>
    </AdminPageHeader>

    <ProjectsTable client:load />
  </div>
</PrivateLayout>
