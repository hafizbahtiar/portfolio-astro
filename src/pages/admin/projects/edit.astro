---
import PrivateLayout from "../../../layouts/PrivateLayout.astro";
import AdminPageHeader from "../../../components/admin/AdminPageHeader.astro";
import AlertToast from "../../../components/ui/AlertToast.astro";
import { ProjectEditor } from "../../../components/admin/projects/ProjectEditor";

const idParam = Astro.url.searchParams.get("id");
const projectId = idParam && /^\d+$/.test(idParam) ? Number(idParam) : undefined;
---

<PrivateLayout title="Edit Project">
  <div class="space-y-6">
    <AdminPageHeader title="Edit Project" description="Manage project content and publishing">
      <a
        slot="actions"
        href="/admin/projects"
        class="admin-btn admin-btn-secondary"
      >
        Back to list
      </a>
    </AdminPageHeader>

    {
      projectId != null ? (
        <ProjectEditor client:load projectId={projectId} />
      ) : (
        <p class="admin-help">Missing or invalid project id.</p>
      )
    }
  </div>
  <AlertToast id="admin-alert" />
</PrivateLayout>
