---
import PrivateLayout from "../../../layouts/PrivateLayout.astro";
import AdminPageHeader from "../../../components/admin/AdminPageHeader.astro";
import { ExperiencesTable } from "../../../components/admin/experiences/ExperiencesTable";
---

<PrivateLayout title="Manage Experiences">
  <div class="space-y-6">
  <AdminPageHeader title="Experiences" description="Manage work history shown on the public timeline.">
      <a slot="actions" href="/admin/experiences/new" class="admin-btn admin-btn-primary">
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 4v16m8-8H4"></path>
        </svg>
        New Experience
      </a>
  </AdminPageHeader>

    <ExperiencesTable client:load />
  </div>
</PrivateLayout>
