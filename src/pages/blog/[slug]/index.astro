                <div class="flex gap-4">
                  <span class="w-6 text-gray-700 text-right">1</span>
                  <span>---</span>
                </div>
                <div class="flex gap-4">
                  <span class="w-6 text-gray-700 text-right">2</span>
                  <span class="text-purple-400">title:</span>
                  <span id="post-title-display" class="text-green-400"
                    >"Post"</span
