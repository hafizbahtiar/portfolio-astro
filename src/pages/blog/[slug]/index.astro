                >
                  <span class="text-blue-400">⚛</span>
                  <span class="h-3 w-20 bg-slate-700 rounded"></span>
                </div>
              </div>
            </div>
            <div class="p-6 md:p-10 space-y-4">
              <div class="space-y-1 border-l-2 border-slate-200 pl-4">
                <div class="flex gap-4">
                  <div class="h-3 w-6 bg-slate-700 rounded"></div><div
                    class="h-3 w-8 bg-slate-700 rounded"
                  >
                  </div>
                </div>
                <div class="flex gap-4">
                  <div class="h-3 w-6 bg-slate-700 rounded"></div><div
                    class="h-3 w-16 bg-slate-700 rounded"
                  >
                  </div><div class="h-3 w-32 bg-slate-700 rounded"></div>
                </div>
                <div class="flex gap-4">
                  <div class="h-3 w-6 bg-slate-700 rounded"></div><div
                    class="h-3 w-16 bg-slate-700 rounded"
                  >
                  </div><div class="h-3 w-20 bg-slate-700 rounded"></div>
                </div>
                <div class="flex gap-4">
                  <div class="h-3 w-6 bg-slate-700 rounded"></div><div
                    class="h-3 w-16 bg-slate-700 rounded"
                  >
                  </div><div class="h-3 w-24 bg-slate-700 rounded"></div>
                </div>
                <div class="flex gap-4">
                  <div class="h-3 w-6 bg-slate-700 rounded"></div><div
                    class="h-3 w-8 bg-slate-700 rounded"
                  >
                  </div>
                </div>
              </div>
              <div class="pl-10 space-y-3">
                <div class="h-8 w-2/3 bg-slate-700 rounded"></div>
                <div class="h-5 w-full bg-slate-700 rounded"></div>
                <div class="h-5 w-4/5 bg-slate-700 rounded"></div>
              </div>
            </div>
          </div>
          <div class="mt-10 space-y-4">
            <div
              class="h-6 w-1/3 bg-slate-200 dark:bg-slate-700 rounded animate-pulse"
