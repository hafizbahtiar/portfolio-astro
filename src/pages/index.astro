---
import PublicLayout from "../layouts/PublicLayout.astro";
import Hero from "../components/home/Hero.astro";
import ContactSection from "../components/home/ContactSection.astro";
import FeaturedProjects from "../components/home/FeaturedProjects.astro";
import MapSection from "../components/home/MapSection.astro";
import { getProjects } from "../lib/projects";
import type { Project } from "../types/project";

let allProjects: Project[] = [];
try {
	allProjects = await getProjects();
} catch (error) {
	console.error("Failed to fetch projects:", error);
}

const skills = [
	{
		category: "Languages",
		items: ["TypeScript", "JavaScript", "Dart", "Kotlin", "Java", "PHP"],
	},
	{
		category: "Backend",
		items: ["Node.js", "Bun", "Hono", "Express.js", "Spring Boot"],
	},
	{
		category: "Mobile",
		items: ["Flutter", "React Native", "Kotlin"],
	},
	{
		category: "Frontend",
		items: ["React", "Next.js", "Astro"],
	},
	{
		category: "Database",
		items: ["PostgreSQL", "MongoDB", "SQLite"],
	},
	{
		category: "Frameworks",
		items: ["Laravel", "CodeIgniter"],
	},
	{
		category: "Infrastructure",
		items: ["Docker", "Linux", "Git", "Caddy", "Cloudflare"],
	},
];
---

<PublicLayout>
	<Hero projectCount={allProjects.length} />

	<div class="container-main space-y-10 md:space-y-14 pb-10 md:pb-14">
		<!-- GitHub Activity -->
		<section id="github-activity" class="scroll-offset">
			<div class="rounded-xl border border-slate-200 bg-white p-4 md:p-5">
				<div class="mb-4 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
					<div>
						<h2 class="text-base font-semibold text-slate-900">GitHub Contributions</h2>
						<p class="text-xs text-slate-400 mt-0.5">Public activity and coding consistency.</p>
					</div>
					<a
						href="https://github.com/hafizbahtiar"
						target="_blank"
						rel="noopener noreferrer"
						class="self-start sm:self-auto inline-flex items-center gap-1.5 rounded-lg border border-slate-300 px-3 py-1.5 text-xs text-slate-500 transition-colors hover:border-slate-400 hover:text-slate-700 shrink-0"
					>
						View Profile
					</a>
				</div>
				<div class="overflow-hidden rounded-xl bg-[#0d1117] p-3 md:p-4">
					<img
						src="https://ghchart.rshah.org/hafizbahtiar"
						alt="GitHub contribution chart for hafizbahtiar"
						class="block w-full"
						referrerpolicy="no-referrer"
					/>
				</div>
			</div>
		</section>

		<!-- Skills Section -->
		<section id="skills" class="scroll-offset">
			<div class="mb-5">
				<h2 class="text-xl md:text-2xl font-bold text-slate-900">Engineering Stack</h2>
				<p class="text-slate-400 text-xs md:text-sm mt-1">Technologies I work with to build production software.</p>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
				{
					skills.map((skillGroup) => (
						<div class="rounded-xl border border-slate-200 bg-slate-50 p-4 hover:border-slate-300 hover:bg-slate-50 transition-colors">
							<h3 class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-3">
								{skillGroup.category}
							</h3>
							<div class="flex flex-wrap gap-1.5">
								{skillGroup.items.map((item) => (
									<span class="text-xs text-slate-700 bg-slate-100 border border-slate-200 rounded-md px-2 py-0.5">
										{item}
									</span>
								))}
							</div>
						</div>
					))
				}
			</div>
		</section>

		<!-- Projects Section -->
		<section id="projects" class="scroll-offset">
			<div class="flex items-end justify-between mb-5">
				<div>
					<h2 class="text-xl md:text-2xl font-bold text-slate-900">Selected Projects</h2>
					<p class="text-slate-400 text-xs md:text-sm mt-1">Recent work in mobile and web development.</p>
				</div>
				<a
					href="/projects"
					class="group inline-flex items-center gap-1 text-xs text-slate-500 hover:text-slate-900 transition-colors shrink-0"
				>
					View all
					<svg class="w-3 h-3 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
					</svg>
				</a>
			</div>
			<FeaturedProjects />
		</section>

		<MapSection />

		<ContactSection />
	</div>
</PublicLayout>
