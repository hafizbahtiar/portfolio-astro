---
import PublicLayout from "../layouts/PublicLayout.astro";
import JsonLd from "../components/seo/JsonLd.astro";
import Hero from "../components/home/Hero.astro";
import ContactSection from "../components/home/ContactSection.astro";
import FeaturedProjects from "../components/home/FeaturedProjects.astro";
import MapSection from "../components/home/MapSection.astro";
import {
	getPublicProjects,
	getPublicExperiences,
} from "../lib/public-content";

// Server-side data with curated fallback — this page never shows loading
// spinners, error banners, or empty states.
const [projects, experiences] = await Promise.all([
	getPublicProjects(),
	getPublicExperiences(),
]);

const FIRST_DEV_ROLE_YEAR = 2020; // Jom Dapur, Sep 2020
const yearsExperience = Math.max(
	1,
	new Date().getFullYear() - FIRST_DEV_ROLE_YEAR,
);

type SkillLevel = "advanced" | "proficient" | "familiar";
interface Skill {
	name: string;
	level: SkillLevel;
}

// Ordered backend-first to match positioning.
const skills: { category: string; items: Skill[] }[] = [
	{
		category: "Backend",
		items: [
			{ name: "Node.js", level: "advanced" },
			{ name: "Express.js", level: "advanced" },
			{ name: "Hono", level: "proficient" },
			{ name: "Bun", level: "proficient" },
			{ name: "Spring Boot", level: "familiar" },
		],
	},
	{
		category: "Mobile",
		items: [
			{ name: "Flutter", level: "advanced" },
			{ name: "React Native", level: "proficient" },
			{ name: "Kotlin (Android)", level: "familiar" },
		],
	},
	{
		category: "Databases",
		items: [
			{ name: "MongoDB", level: "advanced" },
			{ name: "PostgreSQL", level: "proficient" },
			{ name: "SQLite / D1", level: "proficient" },
		],
	},
	{
		category: "Languages",
		items: [
			{ name: "TypeScript", level: "proficient" },
			{ name: "JavaScript", level: "proficient" },
			{ name: "Dart", level: "proficient" },
			{ name: "PHP", level: "proficient" },
			{ name: "Kotlin", level: "familiar" },
			{ name: "Java", level: "familiar" },
		],
	},
	{
		category: "Web",
		items: [
			{ name: "React", level: "familiar" },
			{ name: "Astro", level: "familiar" },
			{ name: "Next.js", level: "familiar" },
		],
	},
	{
		category: "Infrastructure",
		items: [
			{ name: "Cloudflare Workers", level: "proficient" },
			{ name: "Linux", level: "proficient" },
			{ name: "Caddy", level: "proficient" },
			{ name: "Git", level: "proficient" },
			{ name: "Docker", level: "familiar" },
		],
	},
];

const levelStyle: Record<SkillLevel, string> = {
	advanced:
		"bg-cyan-50 dark:bg-cyan-500/10 text-cyan-700 dark:text-cyan-300 border border-cyan-200 dark:border-cyan-500/30",
	proficient:
		"bg-blue-50 dark:bg-blue-500/10 text-blue-700 dark:text-blue-300 border border-blue-200 dark:border-blue-500/30",
	familiar:
		"bg-slate-100 dark:bg-slate-700/70 text-slate-600 dark:text-slate-400 border border-slate-200 dark:border-slate-600",
};

const personSchema = {
	"@context": "https://schema.org",
	"@type": "Person",
	name: "Hafiz Bahtiar",
	jobTitle: "Backend & Flutter Developer",
	description:
		"Backend & Flutter developer building reliable APIs and production Flutter apps.",
	url: "https://hafizbahtiar.com",
	address: {
		"@type": "PostalAddress",
		addressLocality: "Kuala Lumpur",
		addressCountry: "MY",
	},
	sameAs: [
		"https://github.com/hafizbahtiar",
		"https://www.linkedin.com/in/hafizbahtiar/",
	],
};
const websiteSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	name: "Hafiz Bahtiar",
	url: "https://hafizbahtiar.com",
};
---

<PublicLayout>
	<JsonLd schema={personSchema} />
	<JsonLd schema={websiteSchema} />
	<Hero projectCount={projects.length} yearsExperience={yearsExperience} />

	<div class="container-main space-y-14 md:space-y-20 pb-10 md:pb-14">
		<!-- GitHub Activity -->
		<section id="github-activity" class="scroll-offset" data-reveal>
			<div class="section-label">
				<span class="section-index">01 / Activity</span>
				<span class="section-rule"></span>
			</div>
			<div
				class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between mb-5"
			>
				<div>
					<h2 class="section-heading">GitHub contributions</h2>
					<p class="section-sub">
						Public activity and coding consistency.
					</p>
				</div>
				<a
					href="https://github.com/hafizbahtiar"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex min-h-10 shrink-0 items-center justify-center self-start rounded-xl border border-slate-300 bg-white px-4 text-sm font-medium text-slate-600 shadow-sm transition-colors hover:border-slate-400 hover:bg-slate-50 hover:text-slate-900 dark:border-slate-600 dark:bg-slate-800/80 dark:text-slate-300 dark:hover:border-slate-500 dark:hover:bg-slate-800 dark:hover:text-slate-100 sm:self-auto"
				>
					View profile
				</a>
			</div>
			<div
				class="overflow-x-auto rounded-2xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-surface-code p-3 md:p-4"
			>
				<img
					src="https://ghchart.rshah.org/hafizbahtiar"
					alt="GitHub contribution chart for hafizbahtiar"
					id="github-chart"
					width="722"
					height="112"
					loading="lazy"
					decoding="async"
					class="block min-w-[620px] w-full h-auto transition-[filter] duration-300"
					referrerpolicy="no-referrer"
				/>
			</div>
		</section>

		<!-- Skills Section -->
		<section id="skills" class="scroll-offset" data-reveal>
			<div class="section-label">
				<span class="section-index">02 / Stack</span>
				<span class="section-rule"></span>
			</div>
			<div
				class="mb-5 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3"
			>
				<div>
					<h2 class="section-heading">Engineering stack</h2>
					<p class="section-sub">
						Backend first, mobile close behind — the tools I ship
						production software with.
					</p>
				</div>
				<div class="flex items-center gap-3 shrink-0">
					<div class="flex items-center gap-1.5">
						<span class="inline-block w-2 h-2 rounded-full bg-cyan-400"
						></span>
						<span class="text-xs text-slate-500 dark:text-slate-400"
							>Advanced</span
						>
					</div>
					<div class="flex items-center gap-1.5">
						<span class="inline-block w-2 h-2 rounded-full bg-blue-400"
						></span>
						<span class="text-xs text-slate-500 dark:text-slate-400"
							>Proficient</span
						>
					</div>
					<div class="flex items-center gap-1.5">
						<span
							class="inline-block w-2 h-2 rounded-full bg-slate-400 dark:bg-slate-500"
						></span>
						<span class="text-xs text-slate-500 dark:text-slate-400"
							>Familiar</span
						>
					</div>
				</div>
			</div>
			<div class="grid grid-cols-2 md:grid-cols-3 gap-3">
				{
					skills.map((skillGroup, index) => (
						<div
							class="rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800/80 p-4 hover:border-cyan-500/40 dark:hover:border-cyan-400/30 transition-colors"
							data-reveal
							style={`--reveal-delay: ${(index % 3) * 70}ms`}
						>
							<h3 class="font-mono text-[11px] font-medium text-slate-400 dark:text-slate-500 uppercase tracking-[0.18em] mb-3">
								{skillGroup.category}
							</h3>
							<div class="flex flex-wrap gap-1.5">
								{skillGroup.items.map((item) => (
									<span
										class={`text-xs rounded-md px-2 py-0.5 ${levelStyle[item.level]}`}
									>
										{item.name}
									</span>
								))}
							</div>
						</div>
					))
				}
			</div>
		</section>

		<!-- Projects Section -->
		<section id="projects" class="scroll-offset">
			<div data-reveal>
				<div class="section-label">
					<span class="section-index">03 / Selected Work</span>
					<span class="section-rule"></span>
				</div>
				<div class="flex flex-wrap items-end justify-between gap-2 mb-5">
					<div>
						<h2 class="section-heading">Selected projects</h2>
						<p class="section-sub">
							Production systems — marketplaces, government
							platforms, and offline-first apps.
						</p>
					</div>
					<a
						href="/projects"
						class="group inline-flex items-center gap-1 text-sm text-slate-500 dark:text-slate-400 hover:text-cyan-700 dark:hover:text-cyan-400 transition-colors shrink-0"
					>
						View all {projects.length}
						<svg
							class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M9 5l7 7-7 7"></path>
						</svg>
					</a>
				</div>
			</div>
			<FeaturedProjects projects={projects} />
		</section>

		<MapSection experiences={experiences} />

		<ContactSection />
	</div>
</PublicLayout>

<script>
	// The GitHub chart is served light-themed; invert it in dark mode.
	const applyChartFilter = () => {
		const chart = document.getElementById(
			"github-chart",
		) as HTMLImageElement | null;
		if (!chart) return;
		const isDark = document.documentElement.classList.contains("dark");
		chart.style.filter = isDark
			? "invert(1) hue-rotate(180deg) saturate(0.85) brightness(0.9)"
			: "none";
	};

	applyChartFilter();
	document.addEventListener("astro:page-load", applyChartFilter);
	document.addEventListener("astro:after-swap", applyChartFilter);

	const observer = new MutationObserver(applyChartFilter);
	observer.observe(document.documentElement, { attributeFilter: ["class"] });
</script>
