---
import PublicLayout from "../layouts/PublicLayout.astro";
---

<PublicLayout
  title="Page Not Found | Hafiz.dev"
  description="The page you are looking for could not be found."
>
  <section
    class="container-main min-h-[calc(100vh-10rem)] flex items-center py-16"
  >
    <div class="w-full">
      <div
        class="rounded-2xl border border-slate-200 dark:border-slate-700 bg-white/90 dark:bg-slate-800/90 p-5 sm:p-8 md:p-10 shadow-sm backdrop-blur"
      >
        <div
          class="mb-6 inline-flex items-center gap-2 rounded-full border border-blue-200 dark:border-blue-500/30 bg-blue-50 dark:bg-blue-500/10 px-3 py-1 text-xs font-semibold text-blue-700 dark:text-blue-300"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-blue-500"></span>
          404
        </div>

        <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-end">
          <div>
            <h1
              class="text-3xl md:text-5xl font-bold tracking-tight text-slate-900 dark:text-slate-100"
            >
              Page not found
            </h1>
            <p
              class="mt-4 max-w-2xl text-sm md:text-base leading-relaxed text-slate-500 dark:text-slate-400"
            >
              The link may be outdated, moved, or typed incorrectly. You can
              head back home, browse projects, or sign in to the admin
              dashboard.
            </p>

            <div class="mt-8 flex flex-col gap-3 sm:flex-row">
              <a href="/" class="admin-btn admin-btn-primary">
                <svg
                  class="h-4 w-4"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 12l9-9 9 9M5 10v10h14V10"></path>
                </svg>
                Back home
              </a>
              <a href="/projects" class="admin-btn admin-btn-secondary">
                View projects
              </a>
              <a href="/admin" class="admin-btn admin-btn-secondary"> Admin </a>
            </div>
          </div>

          <div
            class="rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900/50 p-4"
          >
            <div class="grid grid-cols-4 gap-2" aria-hidden="true">
              {
                Array.from({ length: 16 }).map((_, index) => (
                  <div
                    class:list={[
                      "aspect-square rounded-md border",
                      index === 5 || index === 6 || index === 9 || index === 10
                        ? "border-blue-300 bg-blue-100 dark:border-blue-500/40 dark:bg-blue-500/20"
                        : "border-slate-200 bg-white dark:border-slate-700 dark:bg-slate-800",
                    ]}
                  />
                ))
              }
            </div>
            <p class="mt-4 text-xs text-slate-500 dark:text-slate-400">
              Nothing broke. This route just does not exist.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</PublicLayout>
